<!DOCTYPE html>
<html lang="pt-br">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Teco - <%= locals.title %>
    </title>
    <link rel="icon" type="image/x-icon" href="/images/icon.ico">
    <link rel="manifest" href="/manifest.json">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Teco">
    <link rel="apple-touch-icon" href="/images/icon.png">
    <meta name="theme-color" content="#000000">
    <link rel="stylesheet" href="/styles/retro.css">
    <style>
        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            margin: 0;
            padding: 10px;
            box-sizing: border-box;
        }

        #main-content {
            flex-grow: 1;
        }
    </style>
    <script>
        // Fallback global para imagens quebradas
        document.addEventListener('error', function (e) {
            if (e.target && e.target.tagName === 'IMG') {
                const fallback = '/images/placeholder.webp';
                if (!e.target.src.includes('placeholder.webp')) {
                    e.target.src = fallback;
                }
            }
        }, true);

        document.addEventListener('DOMContentLoaded', () => {
            const checkFallback = (imgs) => {
                imgs.forEach(img => {
                    const src = img.getAttribute('src');
                    if (!src || src === 'null' || src === 'undefined' || src === '') {
                        if (!img.src.includes('placeholder.webp')) img.src = '/images/placeholder.webp';
                    }
                });
            };

            checkFallback(document.querySelectorAll('img'));

            new MutationObserver(mutations => {
                mutations.forEach(m => {
                    if (m.type === 'childList') {
                        m.addedNodes.forEach(n => {
                            if (n.tagName === 'IMG') checkFallback([n]);
                            else if (n.querySelectorAll) checkFallback(n.querySelectorAll('img'));
                        });
                    } else if (m.type === 'attributes') {
                        checkFallback([m.target]);
                    }
                });
            }).observe(document.body, { childList: true, subtree: true, attributes: true, attributeFilter: ['src'] });
        });
    </script>
</head>

<body>
    <div class="window" style="width: 100%; margin-bottom: 10px; box-sizing: border-box;">
        <div class="window-header">
            <span>Site do Boteco</span>
        </div>
        <div class="window-content"
            style="background: var(--retro-bg); border-bottom: 1px solid var(--retro-border-dark); display: flex; justify-content: space-between; align-items: center; padding-bottom: 5px;padding-top: 5px">
            <div>
                <a href="/"><img src="/images/Teco.webp" alt="Logo" style="height: 40px;"></a>
            </div>
            <div style="display: flex; align-items: center; flex-grow: 1; justify-content: center;">
                <div class="window" style="width: 400px; margin: 0;">
                    <marquee style="background-color: var(--retro-header-bg); color: var(--retro-header-text);">
                        <%= marqueeText %>
                    </marquee>
                </div>
            </div>
            <div id="retro-notifications-container">
                <a href="javascript:void(0)" id="notificationsDropdownBtn"
                    style="text-decoration: none; position: relative; display: inline-flex; align-items: center; justify-content: center; width: 28px; height: 28px; background: var(--retro-bg); border-top: 2px solid var(--retro-border-light); border-left: 2px solid var(--retro-border-light); border-bottom: 2px solid var(--retro-border-dark); border-right: 2px solid var(--retro-border-dark); box-sizing: border-box;">
                    <span style="font-size: 16px; line-height: 1;">🔔</span>
                    <span id="notificationsBadge"
                        style="display: none; background: red; color: white; border-radius: 50%; padding: 2px 5px; font-size: 10px; position: absolute; top: -8px; right: -8px; border: 1px solid white; z-index: 10;">0</span>
                </a>
                <div id="retro-notifications-list" class="window"
                    style="display: none; position: absolute; right: 10px; width: 300px; z-index: 1000; box-shadow: 2px 2px 10px rgba(0,0,0,0.5);">
                    <div class="window-header">
                        <span>Notificações</span>
                        <button onclick="document.getElementById('retro-notifications-list').style.display='none'"
                            style="padding: 0 5px; font-size: 10px;">[Fechar]</button>
                    </div>
                    <div class="window-content"
                        style="background: white; max-height: 400px; overflow-y: auto; padding: 0;">
                        <div id="notificationsList">
                            <div style="text-align: center; padding: 10px;">Carregando...</div>
                        </div>
                        <div
                            style="border-top: 1px solid var(--retro-border-dark); padding: 5px; text-align: center; background: var(--retro-bg);">
                            <a href="javascript:void(0)" id="markAllReadBtn" style="font-size: 11px;">Marcar todas como
                                lidas</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="main-content">
        <%- body %>
    </div>

    <div class="window" style="margin-top: 20px;">
        <div class="window-content" style="text-align: center;">
            <p><a href="/credits" style="text-decoration: none; color: inherit;">Site do Boteco - Teco</a></p>
            <p>&copy; 2024-2026 Boteco | <a href="/changelog" style="text-decoration: none; color: inherit;">Versão: <%=
                        locals.version %></a></p>
            <% if (locals.loggedUser) { %>
                <p>
                    <% if (locals.loggedUser.roleId <=10) { %>
                        <a href="/admin" style="font-size: 11px;">[Painel Admin]</a> |
                        <% } %>
                            <a href="javascript:void(0)" onclick="handleLogout()" style="font-size: 11px;">[Sair]</a>
                </p>
                <% } %>
        </div>
    </div>

    <script>
        async function handleLogout() {
            if (!(await confirm('Deseja realmente sair?'))) return;
            try {
                const res = await fetch('/api/users/logout', { method: 'POST' });
                if (res.ok) {
                    window.location.href = '/';
                } else {
                    window.location.href = '/';
                }
            } catch (e) {
                console.error('Erro no logout:', e);
                window.location.href = '/';
            }
        }
    </script>

    <!-- Script para sobrescrever alert() e confirm() -->
    <script src="/js/commons/modal-aviso.js"></script>

    <!-- Modais globais retrô -->
    <%- include('../utils/modal-aviso') %>
        <%- include('../utils/modal-confirmacao-retro') %>

            <script src="/js/global/socket-connector.js"></script>
            <script>
                const notificationsSocket = SocketConnector.init();
                window.appSocket = notificationsSocket;
                notificationsSocket.emit('joinUserRoom');
            </script>
            <script src="/js/global/user-context.js"></script>
            <script src="/js/commons/retro-ui.js"></script>
            <script src="/js/global/pwa.js?v=2"></script>
</body>

</html>