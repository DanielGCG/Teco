<title>Gerenciar Badges - Administração</title>

<!-- Título da Seção -->
<div class="window" style="margin-bottom: 20px;">
    <div class="window-header">
        <span>Gerenciar Badges</span>
        <a href="/admin" style="text-decoration: none; color: var(--retro-header-text); font-size: 11px;">[ Voltar ao Painel ]</a>
    </div>
    <div class="window-content">
        Administração de badges do sistema e atribuições para usuários.
    </div>
</div>

<div style="display: flex; gap: 20px; align-items: flex-start;">
    <!-- Badges Existentes -->
    <div style="flex: 1;">
        <div class="window">
            <div class="window-header">
                <span>Dicionário de Badges</span>
                <button onclick="abrirModalBadge()" style="height: 16px; line-height: 12px; font-size: 10px;">+ Nova</button>
            </div>
            <div class="window-content" style="padding: 0; background: white; height: 350px; overflow-y: auto; border: 2px inset var(--retro-border-dark);">
                <div id="badgesLista">
                    <!-- Carregado via JS -->
                </div>
            </div>
        </div>
    </div>
    
    <!-- Atribuir Badge -->
    <div style="flex: 1.5;">
        <div class="window">
            <div class="window-header">Distribuição de Badges</div>
            <div class="window-content">
                <div style="display: flex; gap: 5px; align-items: center; margin-bottom: 10px; background: var(--retro-bg); padding: 5px; border: 2px outset var(--retro-border-light);">
                    <input type="text" id="userSearch" placeholder="Buscar @username..." style="flex-grow: 1;" autocomplete="off">
                    <button onclick="carregarAtribuicoes()">Buscar</button>
                    <div id="searchResults" style="display: none; position: absolute; z-index: 100; background: white; border: 1px solid black; width: 100%; max-height: 150px; overflow-y: auto; top: 100%; left: 0;"></div>
                </div>

                <div id="userNotFound" style="display: none; margin-top: 10px; color: red; text-align: center;">
                    Usuário não encontrado.
                </div>

                <div id="userResult" style="display: none; margin-top: 15px; padding-top: 15px; border-top: 1px dashed var(--retro-border-dark);">
                    <div style="display: flex; align-items: center; gap: 15px; margin-bottom: 15px;">
                        <div id="userAvatarPlaceholder" style="width: 50px; height: 50px; flex-shrink: 0; border: 2px inset var(--retro-border-dark);"></div>
                        <div style="line-height: 1.2;">
                            <h3 id="userName" style="margin: 0; font-family: 'MS Sans Serif', sans-serif;">-</h3>
                            <small id="userInternalId" style="color: gray;">-</small>
                        </div>
                    </div>

                    <p style="margin-bottom: 5px;"><strong>Badges Atuais:</strong></p>
                    <div id="userBadges" style="min-height: 50px; border: 2px inset var(--retro-border-dark); background: white; padding: 8px; display: flex; flex-wrap: wrap; gap: 5px; align-content: flex-start;">
                        <!-- Carregado via JS -->
                    </div>

                    <div style="margin-top: 15px; background: #eee; padding: 10px; border: 2px outset var(--retro-border-light);">
                        <strong>Atribuir Nova:</strong>
                        <div style="display: flex; gap: 5px; margin-top: 5px;">
                            <select id="badgeSelect" style="flex-grow: 1;">
                                <option value="">Selecione...</option>
                            </select>
                            <button onclick="atribuirBadge()" style="font-weight: bold;">Atribuir</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal nativo -->
<dialog id="badgeModal" class="window" style="padding: 0; border: 2px outset var(--retro-border-light, #ddd); width: 400px; background: var(--retro-window-bg, #c0c0c0);">
    <div class="window-header">
        <span id="badgeModalTitle">Nova Badge</span>
        <button onclick="fecharModalBadge()">X</button>
    </div>
    <div class="window-content" style="padding: 10px;">
        <input type="hidden" id="badgePublicId">
        <table width="100%" cellpadding="5">
            <tr>
                <td>Nome:</td>
                <td><input type="text" id="badgeName" style="width: 100%; box-sizing: border-box;" required></td>
            </tr>
            <tr>
                <td>Descrição:</td>
                <td><textarea id="badgeDescription" style="width: 100%; box-sizing: border-box;" rows="2"></textarea></td>
            </tr>
            <tr>
                <td colspan="2">Ícone da Badge:</td>
            </tr>
            <tr>
                <td colspan="2">
                    <div style="margin-bottom: 5px; border-bottom: 1px solid var(--retro-border-dark); padding-bottom: 5px;">
                        <label><input type="radio" name="iconType" value="file" checked onchange="document.getElementById('badgeFile').style.display='block'; document.getElementById('badgeUrl').style.display='none';"> Arquivo</label>
                        <label><input type="radio" name="iconType" value="url" style="margin-left: 10px;" onchange="document.getElementById('badgeFile').style.display='none'; document.getElementById('badgeUrl').style.display='block';"> URL</label>
                    </div>
                    <input type="file" id="badgeFile" accept="image/*" style="width: 100%;">
                    <input type="text" id="badgeUrl" placeholder="https://..." style="width: 100%; display: none; box-sizing: border-box;">
                    <div style="text-align: center; margin-top: 10px;">
                        <img id="badgePreview" src="" alt="Preview" style="max-width: 64px; max-height: 64px; display: none;">
                    </div>
                </td>
            </tr>
        </table>
        
        <div style="margin-top: 15px; border-top: 1px solid var(--retro-border-dark); padding-top: 10px; text-align: right;">
            <button id="btnExcluirBadge" onclick="deletarBadge()" style="display: none; float: left; color: red;">Excluir</button>
            <button onclick="fecharModalBadge()">Cancelar</button>
            <button onclick="salvarBadge()" style="font-weight: bold;">Salvar</button>
        </div>
    </div>
</dialog>

<script>
    let tutteLeBadges = [];
    let currentUserBadges = [];
    let selectedUserPublicId = null;

    const badgesLista = document.getElementById('badgesLista');
    const badgeSelect = document.getElementById('badgeSelect');
    const userSearch = document.getElementById('userSearch');
    const userResult = document.getElementById('userResult');
    const userNotFound = document.getElementById('userNotFound');
    const userAvatarPlaceholder = document.getElementById('userAvatarPlaceholder');
    const searchResults = document.getElementById('searchResults');
    const userName = document.getElementById('userName');
    const userBadges = document.getElementById('userBadges');
    
    const badgeModal = document.getElementById('badgeModal');
    const badgeFile = document.getElementById('badgeFile');
    const badgeUrl = document.getElementById('badgeUrl');
    const badgePreview = document.getElementById('badgePreview');

    badgeUrl.addEventListener('input', (e) => {
        badgePreview.src = e.target.value;
        badgePreview.style.display = e.target.value ? 'inline-block' : 'none';
    });

    badgeFile.addEventListener('change', (e) => {
        const file = e.target.files[0];
        if (file) {
            const reader = new FileReader();
            reader.onload = (event) => {
                badgePreview.src = event.target.result;
                badgePreview.style.display = 'inline-block';
            };
            reader.readAsDataURL(file);
        }
    });

    function fecharModalBadge() {
        badgeModal.close();
    }

    async function carregarBadges() {
        try {
            const response = await fetch('/api/admin/badges');
            tutteLeBadges = await response.json();

            // Renderizar Lista e Select usando map/join para eficiência
            badgesLista.innerHTML = tutteLeBadges.length 
                ? tutteLeBadges.map(badge => `
                <div style="border-bottom: 1px dashed var(--retro-border-dark); padding: 5px; cursor: pointer; display: flex; align-items: center; background: white; transition: background 0.2s;" onclick="abrirModalBadge('${badge.publicid}')">
                    <div style="width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; background: #eee; border: 1px inset var(--retro-border-light); margin-right: 10px;">
                        <img src="${badge.url || '/images/default-badge.png'}" style="max-width: 32px; max-height: 32px; object-fit: contain;">
                    </div>
                    <div style="flex-grow: 1;">
                        <strong style="font-size: 13px;">${badge.name}</strong><br>
                        <small style="color: #666;">${badge.description || ''}</small>
                    </div>
                    <div style="color: var(--retro-border-dark); font-size: 18px; padding-right: 5px;">&rsaquo;</div>
                </div>`).join('')
                : '<div style="text-align:center; padding:10px;">Nenhuma badge encontrada.</div>';

            badgeSelect.innerHTML = '<option value="">Selecione uma badge...</option>' + 
                tutteLeBadges.map(b => `<option value="${b.publicid}">${b.name}</option>`).join('');

        } catch (error) {
            console.error(error);
            alert('Erro ao carregar badges');
        }
    }

    function abrirModalBadge(publicid = null) {
        document.getElementById('badgeModalTitle').textContent = publicid ? 'Editar Badge' : 'Nova Badge';
        document.querySelector('input[name="iconType"][value="file"]').click();
        badgeFile.value = '';
        
        const badge = publicid ? tutteLeBadges.find(b => b.publicid === publicid) : null;
        
        document.getElementById('badgePublicId').value = badge ? badge.publicid : '';
        document.getElementById('badgeName').value = badge ? badge.name : '';
        document.getElementById('badgeDescription').value = badge?.description || '';
        badgeUrl.value = badge?.url || '';
        
        document.getElementById('btnExcluirBadge').style.display = badge ? 'block' : 'none';
        badgePreview.style.display = badge?.url ? 'inline-block' : 'none';
        if (badge?.url) badgePreview.src = badge.url;

        badgeModal.showModal();
    }

    async function salvarBadge() {
        const publicid = document.getElementById('badgePublicId').value;
        const name = document.getElementById('badgeName').value;
        
        if (!name) return alert('Nome é obrigatório');

        const formData = new FormData();
        formData.append('name', name);
        formData.append('description', document.getElementById('badgeDescription').value);

        if (document.querySelector('input[name="iconType"]:checked').value === 'file') {
            if (badgeFile.files[0]) formData.append('file', badgeFile.files[0]);
        } else {
            formData.append('url', badgeUrl.value);
        }

        try {
            const response = await fetch(publicid ? `/api/admin/badges/${publicid}` : '/api/admin/badges', {
                method: publicid ? 'PUT' : 'POST',
                body: formData
            });

            if (response.ok) {
                fecharModalBadge();
                carregarBadges();
            } else {
                alert('Erro ao salvar');
            }
        } catch (error) {
            alert('Erro ao conectar com o servidor');
        }
    }

    async function deletarBadge() {
        const publicid = document.getElementById('badgePublicId').value;
        if (!publicid) return;

        let conf = typeof mostrarConfirmacao !== 'undefined' 
            ? await mostrarConfirmacao('Tem certeza que deseja excluir esta badge?', 'Excluir')
            : confirm('Tem certeza que deseja excluir esta badge?');
            
        if (!conf) return;

        const response = await fetch(`/api/admin/badges/${publicid}`, { method: 'DELETE' });
        if (response.ok) {
            fecharModalBadge();
            carregarBadges();
        }
    }

    async function carregarAtribuicoes(userPublicId = null) {
        const query = userSearch.value.trim();
        if (!query && !userPublicId) return;

        try {
            let user = null;
            if (userPublicId) {
                user = await (await fetch(`/api/admin/users/${userPublicId}`)).json();
            } else {
                const users = await (await fetch(`/api/admin/users?search=${encodeURIComponent(query)}`)).json();
                const exact = users.find(u => ('@' + u.username).toLowerCase() === (query.startsWith('@') ? query : '@' + query).toLowerCase());
                
                if (!exact && users.length > 0) {
                    searchResults.innerHTML = users.map(u => {
                        const avatarHTML = typeof UIUtils !== 'undefined' ? UIUtils.createAvatarWithStatus(u, 24) : `<img src="${u.profileimage || '/images/default-avatar.png'}" width="24" height="24">`;
                        return `<div style="padding: 5px; border-bottom: 1px dashed var(--retro-border-dark); cursor: pointer; display: flex; align-items: center; gap: 8px;" onclick="userSearch.value='${u.username}'; document.getElementById('searchResults').style.display='none'; carregarAtribuicoes('${u.publicid}')">
                            <div style="width: 24px; height: 24px; flex-shrink: 0; overflow: hidden; border: 1px inset var(--retro-border-dark);">
                                ${avatarHTML}
                            </div>
                            <span style="font-size: 13px;">${u.username}</span>
                        </div>`;
                    }).join('');
                    searchResults.style.display = 'block';
                    userResult.style.display = 'none';
                    userNotFound.style.display = 'none';
                    return;
                } else if (exact) {
                    user = exact;
                    searchResults.style.display = 'none';
                } else {
                    userNotFound.style.display = 'block';
                    userResult.style.display = 'none';
                    searchResults.style.display = 'none';
                    return;
                }
            }

            if (user && !user.message) exibirUsuario(user);
        } catch (error) {
            alert('Erro ao buscar usuário');
        }
    }

    async function exibirUsuario(user) {
        selectedUserPublicId = user.publicid;
        userName.textContent = user.username;
        document.getElementById('userInternalId').textContent = `ID: ${user.id || '-'}`;
        
        userAvatarPlaceholder.innerHTML = typeof UIUtils !== 'undefined' 
            ? UIUtils.createAvatarWithStatus(user, 48) 
            : `<img src="${user.profileimage || '/images/default-avatar.png'}" style="width: 48px; border: 1px solid var(--retro-border-dark);">`;

        currentUserBadges = await (await fetch(`/api/admin/badges/user/${user.publicid}`)).json();

        userBadges.innerHTML = currentUserBadges.length ? currentUserBadges.map(b => 
            `<div style="display: inline-block; margin: 2px; padding: 2px; border: 1px solid var(--retro-border-dark); background: white;">
                <img src="${b.url || '/images/default-badge.png'}" width="24" height="24" title="${b.name}" style="vertical-align: middle;">
                <button onclick="removerAtribuicao('${b.publicid}')" style="margin-left: 5px; font-size: 10px;">X</button>
            </div>`
        ).join('') : '<span style="color:gray;">Nenhuma badge.</span>';

        userResult.style.display = 'block';
        userNotFound.style.display = 'none';
    }

    async function atribuirBadge() {
        const badgePublicId = badgeSelect.value;
        if (!selectedUserPublicId || !badgePublicId) return alert('Selecione um usuário e uma badge');
        if (currentUserBadges.some(b => b.publicid === badgePublicId)) return alert('Usuário já possui esta badge');

        const response = await fetch('/api/admin/badges/assign', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userPublicId: selectedUserPublicId, badgePublicId: badgePublicId })
        });
        if (response.ok) carregarAtribuicoes(selectedUserPublicId);
    }

    async function removerAtribuicao(badgePublicId) {
        if (!selectedUserPublicId || !badgePublicId) return;

        let conf = typeof mostrarConfirmacao !== 'undefined' 
            ? await mostrarConfirmacao('Remover badge?', 'Remover Atribuição') 
            : confirm('Remover badge?');
            
        if (!conf) return;

        const response = await fetch('/api/admin/badges/unassign', { 
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ userPublicId: selectedUserPublicId, badgePublicId: badgePublicId })
        });
        if (response.ok) carregarAtribuicoes(selectedUserPublicId);
    }

    carregarBadges();
    userSearch.addEventListener('keypress', (e) => { if (e.key === 'Enter') carregarAtribuicoes(); });
    document.addEventListener('click', (e) => {
        if (!searchResults.contains(e.target) && e.target !== userSearch) {
            searchResults.style.display = 'none';
        }
    });
</script>
