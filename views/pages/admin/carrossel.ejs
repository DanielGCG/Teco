<title>Carrossel Principal - Administração</title>

<div class="window-header">
    <span>Carrossel da Página Inicial</span>
    <a href="/admin" style="text-decoration: none; color: var(--retro-header-text); font-size: 11px;">[ Voltar ao Painel ]</a>
</div>

<div class="window-content">
    <div class="window">
        <div class="window-header">Gerenciar Carrossel</div>
        <div class="window-content">
            <p style="font-size: 11px;">Imagens exibidas acima da barra de links na página inicial. Elas trocam a cada 10s.</p>
            
            <fieldset>
                <legend>Adicionar ao Carrossel:</legend>
                <div style="display: flex; gap: 10px; align-items: flex-end; margin-top: 5px;">
                    <div style="flex: 1;">
                        <span style="font-size: 10px;">Imagem:</span>
                        <input type="file" id="carousel-upload" accept="image/*" style="width: 100%;">
                    </div>
                    <div style="flex: 2;">
                        <span style="font-size: 10px;">Link ao clicar (opcional):</span>
                        <input type="text" id="carousel-link" placeholder="Ex: /feed ou https://google.com" style="width: 100%; box-sizing: border-box; padding: 3px;">
                    </div>
                    <button id="add-carousel-btn" class="retro-button">Adicionar</button>
                </div>
            </fieldset>

            <div id="carousel-list" style="display: flex; flex-direction: column; gap: 5px; margin-bottom: 10px;">
                <!-- Itens carregados aqui -->
            </div>
            <div style="text-align: right;">
                <button id="save-carousel-btn" class="retro-button" style="font-weight: bold;">Salvar Carrossel</button>
            </div>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', async () => {
        let currentCarousel = [];
        const carouselList = document.getElementById('carousel-list');
        const addCarouselBtn = document.getElementById('add-carousel-btn');
        const saveCarouselBtn = document.getElementById('save-carousel-btn');

        async function loadIndexConfigs() {
            try {
                const resCar = await fetch('/api/admin/config/index_carousel');
                if (resCar.ok) {
                    const car = await resCar.json();
                    if (car.value) {
                        currentCarousel = JSON.parse(car.value) || [];
                        renderCarousel();
                    }
                }
            } catch (e) { 
                console.error('Erro ao carregar index configs', e); 
            }
        }

        async function saveConfig(key, value, desc) {
            return fetch('/api/admin/config', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ key, value, description: desc })
            });
        }

        async function uploadFile(file) {
            const formData = new FormData();
            formData.append('file', file);
            const res = await fetch('/api/admin/config/upload', {
                method: 'POST',
                body: formData
            });
            if (!res.ok) throw new Error('Upload falhou');
            const data = await res.json();
            return data.url;
        }

        function renderCarousel() {
            carouselList.innerHTML = '';
            if (currentCarousel.length === 0) {
                carouselList.innerHTML = '<div style="font-size:11px; color:gray;">Nenhuma imagem no carrossel.</div>';
                return;
            }
            currentCarousel.forEach((item, index) => {
                const div = document.createElement('div');
                div.style.cssText = 'display: flex; align-items: center; gap: 10px; background: var(--retro-bg); border: 2px outset var(--retro-border-light); padding: 5px;';
                div.innerHTML = `
                    <img src="${item.imageUrl}" style="width: 60px; height: 40px; object-fit: cover; border: 1px solid #ccc;">
                    <div style="flex: 1; font-size: 11px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                        Link: ${item.linkUrl || '(Nenhum)'}
                    </div>
                    <div style="display: flex; gap: 2px;">
                        <button class="retro-button" style="padding: 2px 5px;" ${index === 0 ? 'disabled' : ''} onclick="window.moveCarousel(${index}, -1)">▲</button>
                        <button class="retro-button" style="padding: 2px 5px;" ${index === currentCarousel.length - 1 ? 'disabled' : ''} onclick="window.moveCarousel(${index}, 1)">▼</button>
                        <button class="retro-button" style="padding: 2px 5px; color: red;" onclick="window.removeCarousel(${index})">X</button>
                    </div>
                `;
                carouselList.appendChild(div);
            });
        }

        window.moveCarousel = (index, dir) => {
            const item = currentCarousel.splice(index, 1)[0];
            currentCarousel.splice(index + dir, 0, item);
            renderCarousel();
        };

        window.removeCarousel = (index) => {
            currentCarousel.splice(index, 1);
            renderCarousel();
        };

        addCarouselBtn.addEventListener('click', async () => {
            const fileInput = document.getElementById('carousel-upload');
            const linkInput = document.getElementById('carousel-link');
            if (!fileInput.files[0]) return alert('Selecione uma imagem para o carrossel!', true);

            addCarouselBtn.disabled = true;
            addCarouselBtn.textContent = 'Enviando...';
            try {
                const url = await uploadFile(fileInput.files[0]);
                currentCarousel.push({
                    imageUrl: url,
                    linkUrl: linkInput.value.trim()
                });
                renderCarousel();
                fileInput.value = '';
                linkInput.value = '';
            } catch(e) {
                alert('Erro ao enviar imagem pro carrossel', true);
            } finally {
                addCarouselBtn.disabled = false;
                addCarouselBtn.textContent = 'Adicionar';
            }
        });

        saveCarouselBtn.addEventListener('click', async () => {
            saveCarouselBtn.disabled = true;
            try {
                await saveConfig('index_carousel', JSON.stringify(currentCarousel), 'Lista de imagens do carrossel');
                alert('Carrossel salvo com sucesso!');
            } catch(e) {
                alert('Erro ao salvar carrossel', true);
            } finally {
                saveCarouselBtn.disabled = false;
            }
        });

        loadIndexConfigs();
    });
</script>
