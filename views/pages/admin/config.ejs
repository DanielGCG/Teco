<div class="window-header">
    <span>Configurações Globais</span>
    <a href="/admin" style="text-decoration: none; color: var(--retro-header-text); font-size: 11px;">[ Voltar ao Painel ]</a>
</div>

<div class="window-content">
    <!-- Index Page Configurations -->
    <div class="window">
        <div class="window-header">Fundo Global do Site</div>
        <div class="window-content">
            <p style="font-size: 11px;">Substitui a imagem e cor padrão de fundo do site. (Deixe vazio para usar o padrão)</p>
            <fieldset>
                <legend>Configurar Fundo</legend>
                <div style="display: flex; gap: 15px; flex-wrap: wrap; align-items: flex-end;">
                    <div>
                        <label style="display: block; font-size: 11px; margin-bottom: 3px;">Cor de Fundo:</label>
                        <input type="color" id="global-bg-color" value="#d9d7bf" style="width: 50px; height: 30px; border: 2px inset var(--retro-border-dark);">
                    </div>
                    <div>
                        <label style="display: block; font-size: 11px; margin-bottom: 3px;">Imagem de Fundo:</label>
                        <input type="file" id="global-bg-upload" accept="image/*" style="background: var(--retro-window-bg); border: 2px inset var(--retro-border-dark);">
                    </div>
                    <div>
                        <label style="display: block; font-size: 11px; margin-bottom: 3px;">Modo de Exibição:</label>
                        <select id="global-bg-repeat" style="padding: 4px; border: 2px inset var(--retro-border-dark);">
                            <option value="cover">Cobrir</option>
                            <option value="repeat">Repetir</option>
                        </select>
                    </div>
                    <button id="save-global-bg-btn" class="retro-button" style="font-weight: bold;">Salvar Fundo</button>
                    <button id="remove-global-bg-btn" class="retro-button" style="color: #800000;">Voltar ao Padrão</button>
                </div>
            </fieldset>
            <div id="global-bg-preview-container" style="display: none; border: 2px inset gray; width: 200px; height: 100px; background-size: cover; background-position: center;"></div>
        </div>
    </div>

    <div class="window">
        <div class="window-header">Editar Marquee</div>
        <div class="window-content">
            <p>Este texto aparecerá no topo de todas as páginas com o layout principal.</p>
            <div style="display: flex; gap: 10px; align-items: center;">
                <input type="text" id="marquee-input" style="flex-grow: 1; padding: 5px;" placeholder="Digite o texto do marquee...">
                <button id="save-marquee-btn" class="retro-button">Salvar</button>
            </div>
            <p id="marquee-status" style="margin-top: 10px; font-size: 12px; display: none;"></p>
        </div>
    </div>

    <div class="window">
        <div class="window-header">Garbage Collection</div>
        <div class="window-content">
            <p>Sincroniza os arquivos locais com o servidor de arquivos, removendo arquivos órfãos (arquivos que não existem mais no banco de dados).</p>
            <p style="color: var(--retro-red, #ff4444); margin-top: 5px;"><strong>Atenção:</strong> Esta operação pode ser custosa caso haja muitos arquivos no sistema.</p>
            <div style="display: flex; gap: 10px; align-items: center; margin-top: 10px;">
                <button id="sync-files-btn" class="retro-button">Sincronizar Arquivos Agora</button>
            </div>
            <p id="sync-status" style="margin-top: 10px; font-size: 12px; display: none;"></p>
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', async () => {
        const marqueeInput = document.getElementById('marquee-input');
        const saveBtn = document.getElementById('save-marquee-btn');
        const statusMsg = document.getElementById('marquee-status');

        function showStatus(text, isError = false) {
            statusMsg.textContent = text;
            statusMsg.style.color = isError ? 'red' : 'green';
            statusMsg.style.display = 'block';
            setTimeout(() => { statusMsg.style.display = 'none'; }, 3000);
        }

        // Carregar valor atual
        try {
            const res = await fetch('/api/admin/config/marquee');
            if (res.ok) {
                const config = await res.json();
                marqueeInput.value = config.value;
            }
        } catch (err) {
            console.error('Erro ao carregar marquee:', err);
        }

        // Salvar novo valor
        saveBtn.addEventListener('click', async () => {
            const newValue = marqueeInput.value.trim();
            if (!newValue) return showStatus('O texto não pode estar vazio', true);

            saveBtn.disabled = true;
            try {
                const res = await fetch('/api/admin/config', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ 
                        key: 'marquee', 
                        value: newValue,
                        description: 'Texto que aparece no letreiro do topo do site'
                    })
                });

                if (res.ok) {
                    showStatus('Configuração salva! Atualize a página para ver a mudança.');
                } else {
                    showStatus('Erro ao salvar configuração', true);
                }
            } catch (err) {
                showStatus('Erro na requisição', true);
            } finally {
                saveBtn.disabled = false;
            }
        });

        const syncBtn = document.getElementById('sync-files-btn');
        const syncStatusMsg = document.getElementById('sync-status');

        function showSyncStatus(text, isError = false) {
            syncStatusMsg.textContent = text;
            syncStatusMsg.style.color = isError ? 'red' : 'green';
            syncStatusMsg.style.display = 'block';
            setTimeout(() => { syncStatusMsg.style.display = 'none'; }, 5000);
        }

        if (syncBtn) {
            syncBtn.addEventListener('click', async () => {
                if (!(await confirmRetro('Deseja iniciar o processo de sincronização de arquivos com o servidor? Isso pode demorar um pouco.'))) return;
                
                syncBtn.disabled = true;
                syncBtn.textContent = 'Sincronizando...';
                
                try {
                    const res = await fetch('/api/admin/config/sync-files', { method: 'POST' });
                    const data = await res.json();
                    if (res.ok) {
                        showSyncStatus(data.message || 'Sincronização concluída com sucesso!');
                    } else {
                        showSyncStatus(data.message || 'Erro ao sincronizar', true);
                    }
                } catch (err) {
                    showSyncStatus('Erro na requisição de sincronização', true);
                } finally {
                    syncBtn.disabled = false;
                    syncBtn.textContent = 'Sincronizar Arquivos Agora';
                }
            });
        }

        // ==================== GLOBAL CONFIGS ====================
        const bgColor = document.getElementById('global-bg-color');
        const bgUpload = document.getElementById('global-bg-upload');
        const bgRepeat = document.getElementById('global-bg-repeat');
        const saveBgBtn = document.getElementById('save-global-bg-btn');
        const removeBgBtn = document.getElementById('remove-global-bg-btn');
        const bgPreview = document.getElementById('global-bg-preview-container');

        async function loadIndexConfigs() {
            try {
                // Carrega Fundo Global
                const resBgImg = await fetch('/api/admin/config/global_bg_image');
                if (resBgImg.ok) {
                    const bg = await resBgImg.json();
                    if (bg.value) {
                        bgPreview.style.backgroundImage = `url('${bg.value}')`;
                        bgPreview.style.display = 'block';
                    }
                }
                const resBgColor = await fetch('/api/admin/config/global_bg_color');
                if (resBgColor.ok) {
                    const col = await resBgColor.json();
                    if (col.value) bgColor.value = col.value;
                }
                const resBgRepeat = await fetch('/api/admin/config/global_bg_repeat');
                if (resBgRepeat.ok) {
                    const rep = await resBgRepeat.json();
                    if (rep.value) bgRepeat.value = rep.value;
                }
            } catch (e) { console.error('Erro ao carregar index configs', e); }
        }

        async function saveConfig(key, value, desc) {
            return fetch('/api/admin/config', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ key, value, description: desc })
            });
        }

        async function uploadFile(file) {
            const formData = new FormData();
            formData.append('file', file);
            const res = await fetch('/api/admin/config/upload', {
                method: 'POST',
                body: formData
            });
            if (!res.ok) throw new Error('Upload falhou');
            const data = await res.json();
            return data.url;
        }

        // Fundo Global
        saveBgBtn.addEventListener('click', async () => {
            saveBgBtn.disabled = true;
            try {
                await saveConfig('global_bg_color', bgColor.value, 'Cor de fundo global');
                await saveConfig('global_bg_repeat', bgRepeat.value, 'Modo de repetição do fundo global');

                if (bgUpload.files[0]) {
                    const url = await uploadFile(bgUpload.files[0]);
                    await saveConfig('global_bg_image', url, 'Fundo da página inicial');
                    bgPreview.style.backgroundImage = `url('${url}')`;
                    bgPreview.style.display = 'block';
                    bgUpload.value = '';
                }
                
                if (bgRepeat.value === 'repeat') {
                    bgPreview.style.backgroundSize = 'auto';
                    bgPreview.style.backgroundRepeat = 'repeat';
                } else {
                    bgPreview.style.backgroundSize = 'cover';
                    bgPreview.style.backgroundRepeat = 'no-repeat';
                }

                alert('Fundo global salvo com sucesso!');
            } catch(e) {
                alert('Erro ao salvar fundo');
            } finally {
                saveBgBtn.disabled = false;
            }
        });

        removeBgBtn.addEventListener('click', async () => {
            if (!(await confirmRetro('Deseja remover a imagem de fundo e voltar para a cor padrão do site?'))) return;
            try {
                await saveConfig('global_bg_image', '', 'Fundo da página inicial');
                await saveConfig('global_bg_color', '#d9d7bf', 'Cor de fundo global');
                
                bgPreview.style.backgroundImage = '';
                bgPreview.style.display = 'none';
                bgColor.value = '#d9d7bf';
                alert('Fundo restaurado ao padrão!');
            } catch (e) {}
        });

        loadIndexConfigs();
    });
</script>
