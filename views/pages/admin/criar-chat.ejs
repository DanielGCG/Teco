<title>Gerenciar Chats & DMs - Administração</title>

<div class="window" style="margin-bottom: 20px;">
    <div class="window-header">
        <span>Estatísticas de Chats & DMs</span>
        <a href="/admin" style="text-decoration: none; color: var(--retro-header-text); font-size: 11px;">[ Voltar ao Painel ]</a>
    </div>
    <div class="window-content">
        <table width="100%">
            <tr>
                <td align="center"><strong>Chats:</strong> <span id="statChats">-</span></td>
                <td align="center"><strong>DMs:</strong> <span id="statDms">-</span></td>
                <td align="center"><strong>Mensagens:</strong> <span id="statMsgs">-</span></td>
            </tr>
        </table>
    </div>
</div>

<table width="100%" cellpadding="10" cellspacing="0" border="0" style="margin-bottom: 20px;">
    <tr>
        <td valign="top" width="50%" style="border-right: 2px outset var(--retro-border-light);">
            <!-- Novo Chat Público -->
            <div class="window">
                <div class="window-header">Novo Chat Público</div>
                <div class="window-content">
                    <table width="100%" cellpadding="5">
                        <tr>
                            <td>Nome do Chat:</td>
                            <td><input type="text" id="publicChatName" placeholder="Ex: Cantinho do Café" style="width: 100%; box-sizing: border-box;"></td>
                        </tr>
                        <tr>
                            <td>Assunto/Tópico:</td>
                            <td><select id="publicChatTopic" style="width: 100%; box-sizing: border-box;"></select></td>
                        </tr>
                        <tr>
                            <td colspan="2" align="right">
                                <button id="createPublicChatBtn" style="font-weight: bold;">Criar Chat</button>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </td>
        <td valign="top" width="50%">
            <!-- Criar DM (Admin) -->
            <div class="window">
                <div class="window-header">Criar DM (Admin)</div>
                <div class="window-content">
                    <table width="100%" cellpadding="5">
                        <tr>
                            <td>Usuário 1 (Remetente):</td>
                            <td><select id="adminUser1" style="width: 100%; box-sizing: border-box;"></select></td>
                        </tr>
                        <tr>
                            <td>Usuário 2 (Destinado):</td>
                            <td><select id="adminUser2" style="width: 100%; box-sizing: border-box;"></select></td>
                        </tr>
                        <tr>
                            <td colspan="2" align="right">
                                <button id="createAdminDmBtn" style="font-weight: bold;">Criar DM</button>
                            </td>
                        </tr>
                    </table>
                </div>
            </div>
        </td>
    </tr>
</table>

<!-- Lista de chats com busca -->
<div class="window">
    <div class="window-header">
        Conversas Ativas
    </div>
    <div style="background: var(--retro-bg); border-bottom: 2px solid var(--retro-border-dark); padding: 5px; display: flex; gap: 5px; align-items: center;">
        <input type="text" id="chatSearchInput" placeholder="Buscar por título ou participante..." style="flex-grow: 1;">
        <button id="refreshBtn">Atualizar</button>
    </div>
    <div class="window-content" style="padding: 0; background: var(--retro-bg); height: 400px; overflow-y: auto;">
        <div id="chatList">
            <div style="padding: 20px; text-align: center; color: gray;">Carregando...</div>
        </div>
    </div>
    <div style="padding: 5px; background: var(--retro-window-bg); border-top: 2px outset var(--retro-border-light); text-align: center;" id="pagination">
        <!-- Paginação -->
    </div>
</div>

<!-- Modal de edição nativo -->
<dialog id="editChatModal" class="window" style="padding: 0; border: 2px outset var(--retro-border-light, #ddd); width: 400px; background: var(--retro-window-bg, #c0c0c0);">
    <div class="window-header">
        <span id="editChatModalTitle">Administrar Conversa</span>
        <button type="button" class="window-btn" onclick="document.getElementById('editChatModal').close()" style="float: right;">[Fechar]</button>
    </div>
    <div class="window-content" style="padding: 10px;">
        <div style="display: flex; flex-direction: column; gap: 10px;">
            <div id="editChatNameGroup">
                <label for="editChatName" style="display: block; margin-bottom: 5px; font-weight: bold;">Nome do chat:</label>
                <input type="text" id="editChatName" style="width: 100%; box-sizing: border-box;">
            </div>
            
            <div id="editParticipantsContainer" style="display: none;">
                <label style="display: block; margin-bottom: 5px; font-weight: bold;">Participantes:</label>
                <div style="display: flex; gap: 10px;">
                    <div style="flex: 1;">
                        <select id="editParticipant1" style="width: 100%; box-sizing: border-box;"></select>
                    </div>
                    <div style="flex: 1;">
                        <select id="editParticipant2" style="width: 100%; box-sizing: border-box;"></select>
                    </div>
                </div>
            </div>
        </div>
        
        <div style="margin-top: 10px; color: red; font-size: 11px;">
            A exclusão removerá todas as mensagens permanentemente.
        </div>
        
        <hr style="margin-top: 15px; border-top: 1px solid gray;">
        
        <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 10px;">
            <button type="button" class="window-btn" id="deleteChatBtn" style="color: red;">Excluir Definitivamente</button>
            <div style="display: flex; gap: 5px;">
                <button type="button" class="window-btn" id="saveChatBtn" style="font-weight: bold;">Salvar Alterações</button>
                <button type="button" class="window-btn" onclick="document.getElementById('editChatModal').close()">Cancelar</button>
            </div>
        </div>
    </div>
</dialog>

<script>
// ==================== Estado & Configs ====================
let currentPage = 1;
let currentChat = null;
const ITEMS_PER_PAGE = 15;

// ==================== Inicialização ====================
document.addEventListener('DOMContentLoaded', () => {
    carregarTudo();
    
    const debounceSearch = (typeof UIUtils !== 'undefined' && UIUtils.debounce) 
        ? UIUtils.debounce(() => { currentPage = 1; carregarChats(); }, 500)
        : () => {};

    document.getElementById('chatSearchInput').addEventListener('input', debounceSearch);
    document.getElementById('chatSearchInput').addEventListener('keypress', (e) => { 
        if (e.key === 'Enter') { currentPage = 1; carregarChats(); }
    });
    
    document.getElementById('refreshBtn').addEventListener('click', carregarTudo);
    document.getElementById('saveChatBtn').addEventListener('click', salvarAlteracoes);
    document.getElementById('deleteChatBtn').addEventListener('click', deletarChat);
});

function carregarTudo() {
    carregarChats();
    carregarEstatisticas();
    carregarTopicos();
    carregarUsuariosAdmin();
}

// ==================== APIs ====================
async function carregarChats() {
    const list = document.getElementById("chatList");
    try {
        const search = document.getElementById("chatSearchInput").value.trim();
        const params = new URLSearchParams({ page: currentPage, limit: ITEMS_PER_PAGE });
        if (search) params.append('search', search);

        const res = await fetch(`/api/admin/chats?${params}`, { credentials: "include" });
        const data = await res.json();
        
        renderizarChats(data.chats || []);
        renderizarPaginacao(data.currentPage, data.totalPages);
    } catch (err) {
        list.innerHTML = `<div style="padding: 20px; color: red; text-align: center;">Erro ao carregar conversas.</div>`;
    }
}

async function carregarEstatisticas() {
    try {
        const res = await fetch('/api/admin/chats/estatisticas', { credentials: "include" });
        if (res.ok) {
            const s = await res.json();
            document.getElementById('statChats').textContent = s.chatcount || 0;
            document.getElementById('statDms').textContent = s.dmcount || 0;
            document.getElementById('statMsgs').textContent = s.messagecount || 0;
        }
    } catch (e) {}
}

// ==================== Renderização ====================
function renderizarChats(chats) {
    const container = document.getElementById("chatList");
    if (!chats.length) {
        container.textContent = "";
        const emptyMsg = document.createElement("div");
        emptyMsg.style.cssText = "padding: 20px; text-align: center; color: gray;";
        emptyMsg.textContent = "Nenhuma conversa encontrada.";
        container.appendChild(emptyMsg);
        return;
    }

    // Criar fragmento para melhor performance
    const fragment = document.createDocumentFragment();

    chats.forEach(chat => {
        const date = chat.lastmessageat && !isNaN(new Date(chat.lastmessageat)) 
            ? (typeof UIUtils !== 'undefined' ? UIUtils.formatarData(chat.lastmessageat) : new Date(chat.lastmessageat).toLocaleDateString('pt-BR')) 
            : 'Nenhuma msg';
        const isPublic = chat.type === 'public';
        const color = isPublic ? '#000080' : '#008000';
        const tipoText = chat.type.toUpperCase();

        const row = document.createElement("div");
        row.style.cssText = "border-bottom: 2px outset var(--retro-border-light); padding: 8px; background: var(--retro-bg); display: flex; align-items: center; gap: 10px;";
        
        row.innerHTML = `
            <div style="width: 4px; height: 32px; background: ${color}; flex-shrink: 0;"></div>
            <div style="flex-grow: 1;">
                <strong style="font-size: 14px;">${chat.title}</strong> 
                <span style="background: ${color}; color: white; border: 1px inset var(--retro-border-light); padding: 0 4px; font-size: 10px; vertical-align: middle;">${tipoText}</span>
                <div style="margin-top: 2px; color: #444; font-size: 11px;">
                    ${isPublic ? 'Tópico: ' + chat.topic : 'DM Privada'} | 
                    Criador: ${chat.creatorusername} | 
                    <strong>${chat.messagecount}</strong> msgs
                </div>
            </div>
            <div style="text-align: right; font-size: 11px; color: #666; width: 100px; font-family: monospace;">
                Atividade<br>
                <strong style="color: black;">${date}</strong>
            </div>
        `;

        const actions = document.createElement("div");
        actions.style.cssText = "display: flex; flex-direction: column; gap: 3px;";

        const editBtn = document.createElement("button");
        editBtn.textContent = "Editar";
        editBtn.onclick = () => abrirEdicao(chat);
        actions.appendChild(editBtn);

        if (isPublic) {
            const openLink = document.createElement("a");
            openLink.href = `/chat/${chat.publicid}`;
            openLink.target = "_blank";
            openLink.style.textDecoration = "none";
            const openBtn = document.createElement("button");
            openBtn.textContent = "Abrir";
            openBtn.style.width = "100%";
            openLink.appendChild(openBtn);
            actions.appendChild(openLink);
        }

        row.appendChild(actions);
        fragment.appendChild(row);
    });

    container.innerHTML = "";
    container.appendChild(fragment);
}

function renderizarPaginacao(curr, total) {
    const container = document.getElementById("pagination");
    if (total <= 1) { container.innerHTML = ''; return; }
    
    let html = `<button ${curr === 1 ? 'disabled' : ''} onclick="mudarPagina(${curr - 1})">&laquo;</button> `;
    for (let i = Math.max(1, curr - 2); i <= Math.min(total, curr + 2); i++) {
        html += `<button ${i === curr ? 'disabled style="font-weight: bold;"' : ''} onclick="mudarPagina(${i})">${i}</button> `;
    }
    html += `<button ${curr === total ? 'disabled' : ''} onclick="mudarPagina(${curr + 1})">&raquo;</button>`;
    container.innerHTML = html;
}

// ==================== Logica de Negocio ====================
function abrirEdicao(chat) {
    currentChat = chat;
    const isDM = chat.type === 'dm';
    
    document.getElementById("editChatName").value = chat.title || "";
    document.getElementById("editChatNameGroup").style.display = isDM ? "none" : ""; // Tr é display:table-row ou ""  
    document.getElementById("editParticipantsContainer").style.display = isDM ? "" : "none";

    if (isDM) {
        document.getElementById("editParticipant1").value = chat.participants[0]?.publicid || "";
        document.getElementById("editParticipant2").value = chat.participants[1]?.publicid || "";
    }
    
    document.getElementById('editChatModal').showModal();
}

async function salvarAlteracoes() {
    try {
        const body = { 
            title: document.getElementById("editChatName").value.trim(),
            type: currentChat.type,
            participants: currentChat.type === 'dm' ? [
                document.getElementById("editParticipant1").value,
                document.getElementById("editParticipant2").value
            ] : []
        };

        const res = await fetch(`/api/admin/chats/${currentChat.publicid}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(body),
            credentials: "include"
        });

        if (res.ok) {
            mostrarToast("Conversa atualizada!");
            carregarChats();
            document.getElementById('editChatModal').close();
        } else {
            const err = await res.json();
            mostrarToast("Erro: " + (err.error || "Tente novamente"), "error");
        }
    } catch (e) { mostrarToast("Erro ao salvar", "error"); }
}

async function deletarChat() {
    const confirmed = typeof mostrarConfirmacao !== 'undefined' 
        ? await mostrarConfirmacao('Excluir permanentemente todas as mensagens deste chat?', 'Excluir Chat')
        : await confirm('Excluir permanentemente todas as mensagens?');
        
    if (!confirmed) return;

    try {
        const res = await fetch(`/api/admin/chats/${currentChat.publicid}?type=${currentChat.type}`, {
            method: "DELETE",
            credentials: "include"
        });
        if (res.ok) {
            mostrarToast("Excluído com sucesso");
            carregarChats();
            document.getElementById('editChatModal').close();
        }
    } catch (e) { mostrarToast("Erro ao excluir", "error"); }
}

// Criação
document.getElementById("createPublicChatBtn").addEventListener("click", async () => {
    const title = document.getElementById("publicChatName").value.trim();
    const topic = document.getElementById("publicChatTopic").value;
    if (!title) return mostrarToast("Digite um nome", "warning");

    try {
        const res = await fetch(`/api/admin/chats/public`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ title, topic }),
            credentials: "include"
        });
        if (res.ok) {
            mostrarToast("Chat criado!");
            document.getElementById("publicChatName").value = "";
            carregarChats();
        }
    } catch (e) { mostrarToast("Erro ao criar", "error"); }
});

document.getElementById("createAdminDmBtn").addEventListener("click", async () => {
    const u1 = document.getElementById("adminUser1").value;
    const u2 = document.getElementById("adminUser2").value;
    if (!u1 || !u2 || u1 === u2) return mostrarToast("Selecione usuários diferentes", "warning");

    try {
        const res = await fetch(`/api/admin/chats/dm`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ otherUserPublicId: u2, creatorPublicId: u1 }),
            credentials: "include"
        });
        if (res.ok) {
            mostrarToast("DM criada!");
            carregarChats();
        } else {
            const err = await res.json();
            mostrarToast("Erro: " + (err.error || "Tente novamente"), "error");
        }
    } catch (e) { mostrarToast("Erro ao criar DM", "error"); }
});

// Auxiliares
async function carregarTopicos() {
    try {
        const res = await fetch(`/api/admin/chats/topics`, { credentials: "include" });
        const topics = await res.json();
        document.getElementById("publicChatTopic").innerHTML = topics.map(t => `<option value="${t.name}">${t.name}</option>`).join("");
    } catch (e) {}
}

async function carregarUsuariosAdmin() {
    try {
        const res = await fetch(`/api/admin/users`, { credentials: "include" });
        const data = await res.json();
        const users = data.users || data;
        const html = '<option value="">Selecione...</option>' + users.map(u => `<option value="${u.publicid}">${u.username}</option>`).join("");
        ["adminUser1", "adminUser2", "editParticipant1", "editParticipant2"].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.innerHTML = html;
        });
    } catch (e) {}
}

function mudarPagina(p) { currentPage = p; carregarChats(); }

function mostrarToast(m, t = "success") {
    if (typeof UIUtils !== 'undefined' && UIUtils.mostrarFeedback) {
        UIUtils.mostrarFeedback(m, t === "error" ? "danger" : t);
    } else { 
        alert(m); 
    }
}
</script>
