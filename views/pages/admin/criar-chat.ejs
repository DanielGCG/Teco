<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="mb-0"><span class="marca-texto-roxo">Gerenciar Chats & DMs</span></h2>
        <div id="estatisticasGerais" class="d-flex gap-3">
            <div class="text-center">
                <h5 class="mb-0" id="statChats">-</h5>
                <small class="text-muted">Chats</small>
            </div>
            <div class="text-center border-start ps-3">
                <h5 class="mb-0" id="statDms">-</h5>
                <small class="text-muted">DMs</small>
            </div>
            <div class="text-center border-start ps-3">
                <h5 class="mb-0" id="statMsgs">-</h5>
                <small class="text-muted">Mensagens</small>
            </div>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <!-- Criar chat público -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-transparent border-0">
                    <h5 class="mb-0"><span class="marca-texto-verde">Novo Chat Público</span></h5>
                </div>
                <div class="card-body">
                    <div class="mb-2">
                        <label class="form-label small">Nome do Chat</label>
                        <input type="text" id="publicChatName" class="form-control mb-2" placeholder="Ex: Cantinho do Café">
                        <label class="form-label small">Assunto/Tópico</label>
                        <select id="publicChatTopic" class="form-select mb-3"></select>
                        <button class="btn btn-primary w-100" id="createPublicChatBtn">
                            <i class="fas fa-plus-circle me-1"></i> Criar Chat
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Criar DM entre dois usuários -->
        <div class="col-md-6">
            <div class="card h-100">
                <div class="card-header bg-transparent border-0">
                    <h5 class="mb-0"><span class="marca-texto-verde">Criar DM (Admin)</span></h5>
                </div>
                <div class="card-body">
                    <div id="adminDmPanel">
                        <label class="form-label small">Usuário 1 (Remetente)</label>
                        <select id="adminUser1" class="form-select mb-2"></select>
                        <label class="form-label small">Usuário 2 (Destinatário)</label>
                        <select id="adminUser2" class="form-select mb-3"></select>
                        <button class="btn btn-success w-100" id="createAdminDmBtn">
                            <i class="fas fa-comments me-1"></i> Criar DM
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Lista de chats com busca -->
    <div class="card shadow-sm">
        <div class="card-header py-3">
            <div class="row align-items-center">
                <div class="col-md-4">
                    <h5 class="mb-0">Conversas Ativas</h5>
                </div>
                <div class="col-md-8">
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0"><i class="fas fa-search text-muted"></i></span>
                        <input type="text" id="chatSearchInput" class="form-control border-start-0" placeholder="Buscar por título ou participante...">
                        <button class="btn btn-outline-secondary" id="refreshBtn">🔄</button>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div id="chatList">
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            </div>
        </div>
        <div class="card-footer border-top-0 py-3">
            <nav id="paginationContainer">
                <ul class="pagination justify-content-center mb-0" id="pagination"></ul>
            </nav>
        </div>
    </div>
</div>

<!-- Modal de edição -->
<div class="modal fade" id="editChatModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Administrar Conversa</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Fechar"></button>
      </div>
      <div class="modal-body">
        <div id="editChatFields">
          <div class="mb-3" id="editChatNameGroup">
            <label for="editChatName" class="form-label">Nome do chat</label>
            <input type="text" id="editChatName" class="form-control">
          </div>
          <div class="mb-3" id="editParticipantsContainer" style="display:none;">
            <label class="form-label">Participantes</label>
            <div class="row g-2">
                <div class="col-6"><select id="editParticipant1" class="form-select"></select></div>
                <div class="col-6"><select id="editParticipant2" class="form-select"></select></div>
            </div>
          </div>
        </div>
        <div class="alert alert-warning small py-2">
            <i class="fas fa-exclamation-triangle me-2"></i>
            A exclusão removerá todas as mensagens permanentemente.
        </div>
        <div class="d-grid gap-2">
            <button class="btn btn-primary" id="saveChatBtn">Salvar Alterações</button>
            <button class="btn btn-outline-danger" id="deleteChatBtn">
                <i class="fas fa-trash-alt me-1"></i> Excluir Definitivamente
            </button>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
    .chat-row { transition: background 0.2s; border-bottom: 1px solid #eee; }
    .chat-row:last-child { border-bottom: none; }
    .chat-row:hover { background-color: #f8f9fa; }
    .status-indicator { width: 4px; height: 100%; position: absolute; left: 0; top: 0; }
    .type-public { background: #0d6efd; }
    .type-dm { background: #198754; }
    .btn-icon { width: 32px; height: 32px; padding: 0; display: inline-flex; align-items: center; justify-content: center; border-radius: 6px; }
</style>

<script>
// ==================== Estado & Configs ====================
let currentPage = 1;
let currentChat = null;
const ITEMS_PER_PAGE = 15;

// ==================== Inicialização ====================
document.addEventListener('DOMContentLoaded', () => {
    carregarTudo();
    
    const debounceSearch = (typeof UIUtils !== 'undefined' && UIUtils.debounce) 
        ? UIUtils.debounce(() => { currentPage = 1; carregarChats(); }, 500)
        : () => {};

    document.getElementById('chatSearchInput').addEventListener('input', debounceSearch);
    document.getElementById('refreshBtn').addEventListener('click', carregarTudo);
    document.getElementById('saveChatBtn').addEventListener('click', salvarAlteracoes);
    document.getElementById('deleteChatBtn').addEventListener('click', deletarChat);
});

function carregarTudo() {
    carregarChats();
    carregarEstatisticas();
    carregarTopicos();
    carregarUsuariosAdmin();
}

// ==================== APIs ====================
async function carregarChats() {
    const list = document.getElementById("chatList");
    try {
        const search = document.getElementById("chatSearchInput").value.trim();
        const params = new URLSearchParams({ page: currentPage, limit: ITEMS_PER_PAGE });
        if (search) params.append('search', search);

        const res = await fetch(`/api/admin/chats?${params}`, { credentials: "include" });
        const data = await res.json();
        
        renderizarChats(data.chats || []);
        renderizarPaginacao(data.currentPage, data.totalPages);
    } catch (err) {
        list.innerHTML = `<div class="p-4 text-danger">Erro ao carregar conversas.</div>`;
    }
}

async function carregarEstatisticas() {
    try {
        const res = await fetch('/api/admin/chats/estatisticas', { credentials: "include" });
        if (res.ok) {
            const s = await res.json();
            document.getElementById('statChats').textContent = s.chatcount || 0;
            document.getElementById('statDms').textContent = s.dmcount || 0;
            document.getElementById('statMsgs').textContent = s.messagecount || 0;
        }
    } catch (e) {}
}

// ==================== Renderização ====================
function renderizarChats(chats) {
    const container = document.getElementById("chatList");
    if (!chats.length) {
        container.innerHTML = `<div class="p-5 text-center text-muted">Nenhuma conversa encontrada.</div>`;
        return;
    }

    container.innerHTML = chats.map(chat => {
        const date = chat.lastmessageat ? (typeof UIUtils !== 'undefined' ? UIUtils.formatarData(chat.lastmessageat) : new Date(chat.lastmessageat).toLocaleDateString()) : '-';
        const isPublic = chat.type === 'public';
        
        return `
            <div class="chat-row p-3 position-relative d-flex align-items-center">
                <div class="status-indicator ${isPublic ? 'type-public' : 'type-dm'}"></div>
                <div class="flex-grow-1 ms-2">
                    <div class="d-flex align-items-center gap-2">
                        <h6 class="mb-0 fw-bold">${chat.title}</h6>
                        <span class="badge ${isPublic ? 'bg-primary' : 'bg-success'} opacity-75 small">${chat.type.toUpperCase()}</span>
                    </div>
                    <small class="text-muted">
                        ${isPublic ? `Tópico: ${chat.topic}` : 'DM Privada'} | 
                        Criador: ${chat.creatorusername} | 
                        ${chat.messagecount} mensagens
                    </small>
                </div>
                <div class="text-end me-3 d-none d-md-block">
                    <small class="text-muted d-block">Atividade</small>
                    <small class="fw-bold">${date}</small>
                </div>
                <div class="d-flex gap-2">
                    <button class="btn btn-outline-primary btn-icon" onclick="abrirEdicao(${JSON.stringify(chat).replace(/"/g, '&quot;')})" title="Editar Configurações">
                        <i class="bi bi-nut-fill"></i>
                    </button>
                    ${isPublic ? `
                        <a href="/chat/${chat.publicid}" target="_blank" class="btn btn-success btn-icon border-0" title="Abrir Chat Público">
                            <i class="bi bi-chat-fill"></i>
                        </a>
                    ` : `
                        <button class="btn btn-outline-secondary btn-icon" disabled title="Acesso a DMs restrito por privacidade">
                            <i class="bi bi-chat"></i>
                        </button>
                    `}
                </div>
            </div>
        `;
    }).join('');
}

function renderizarPaginacao(curr, total) {
    const container = document.getElementById("pagination");
    if (total <= 1) { container.innerHTML = ''; return; }
    
    let html = `<li class="page-item ${curr === 1 ? 'disabled' : ''}"><a class="page-link" href="#" onclick="mudarPagina(${curr - 1})">«</a></li>`;
    for (let i = Math.max(1, curr - 2); i <= Math.min(total, curr + 2); i++) {
        html += `<li class="page-item ${i === curr ? 'active' : ''}"><a class="page-link" href="#" onclick="mudarPagina(${i})">${i}</a></li>`;
    }
    html += `<li class="page-item ${curr === total ? 'disabled' : ''}"><a class="page-link" href="#" onclick="mudarPagina(${curr + 1})">»</a></li>`;
    container.innerHTML = html;
}

// ==================== Logica de Negocio ====================
function abrirEdicao(chat) {
    currentChat = chat;
    const isDM = chat.type === 'dm';
    
    document.getElementById("editChatName").value = chat.title || "";
    document.getElementById("editChatNameGroup").style.display = isDM ? "none" : "block";
    document.getElementById("editParticipantsContainer").style.display = isDM ? "block" : "none";

    if (isDM) {
        document.getElementById("editParticipant1").value = chat.participants[0]?.publicid || "";
        document.getElementById("editParticipant2").value = chat.participants[1]?.publicid || "";
    }
    
    new bootstrap.Modal(document.getElementById('editChatModal')).show();
}

async function salvarAlteracoes() {
    try {
        const body = { 
            title: document.getElementById("editChatName").value.trim(),
            type: currentChat.type,
            participants: currentChat.type === 'dm' ? [
                document.getElementById("editParticipant1").value,
                document.getElementById("editParticipant2").value
            ] : []
        };

        const res = await fetch(`/api/admin/chats/${currentChat.publicid}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(body),
            credentials: "include"
        });

        if (res.ok) {
            mostrarToast("Conversa atualizada!");
            carregarChats();
            bootstrap.Modal.getInstance(document.getElementById('editChatModal')).hide();
        }
    } catch (e) { mostrarToast("Erro ao salvar", "danger"); }
}

async function deletarChat() {
    if (!confirm("Excluir permanentemente todas as mensagens?")) return;
    try {
        const res = await fetch(`/api/admin/chats/${currentChat.publicid}?type=${currentChat.type}`, {
            method: "DELETE",
            credentials: "include"
        });
        if (res.ok) {
            mostrarToast("Excluído com sucesso");
            carregarChats();
            bootstrap.Modal.getInstance(document.getElementById('editChatModal')).hide();
        }
    } catch (e) { mostrarToast("Erro ao excluir", "danger"); }
}

// Criação
document.getElementById("createPublicChatBtn").addEventListener("click", async () => {
    const title = document.getElementById("publicChatName").value.trim();
    const topic = document.getElementById("publicChatTopic").value;
    if (!title) return mostrarToast("Digite um nome", "warning");

    try {
        const res = await fetch(`/api/admin/chats/public`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ title, topic }),
            credentials: "include"
        });
        if (res.ok) {
            mostrarToast("Chat criado!");
            document.getElementById("publicChatName").value = "";
            carregarChats();
        }
    } catch (e) { mostrarToast("Erro ao criar", "danger"); }
});

document.getElementById("createAdminDmBtn").addEventListener("click", async () => {
    const u1 = document.getElementById("adminUser1").value;
    const u2 = document.getElementById("adminUser2").value;
    if (!u1 || !u2 || u1 === u2) return mostrarToast("Selecione usuários diferentes", "warning");

    try {
        const res = await fetch(`/api/admin/chats/dm`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ otherUserPublicId: u2, creatorPublicId: u1 }),
            credentials: "include"
        });
        if (res.ok) {
            mostrarToast("DM criada!");
            carregarChats();
        }
    } catch (e) { mostrarToast("Erro ao criar DM", "danger"); }
});

// Auxiliares
async function carregarTopicos() {
    try {
        const res = await fetch(`/api/admin/chats/topics`, { credentials: "include" });
        const topics = await res.json();
        document.getElementById("publicChatTopic").innerHTML = topics.map(t => `<option value="${t.name}">${t.name}</option>`).join("");
    } catch (e) {}
}

async function carregarUsuariosAdmin() {
    try {
        const res = await fetch(`/api/admin/users`, { credentials: "include" });
        const data = await res.json();
        const users = data.users || data;
        const html = '<option value="">Selecione...</option>' + users.map(u => `<option value="${u.publicid}">${u.username}</option>`).join("");
        ["adminUser1", "adminUser2", "editParticipant1", "editParticipant2"].forEach(id => {
            const el = document.getElementById(id);
            if (el) el.innerHTML = html;
        });
    } catch (e) {}
}

function mudarPagina(p) { currentPage = p; carregarChats(); }

function mostrarToast(m, t = "success") {
    if (typeof UIUtils !== 'undefined' && UIUtils.mostrarFeedback) {
        UIUtils.mostrarFeedback(m, t);
    } else { alert(m); }
}
</script>
</script>
