<title>Gerenciar Imagem do Dia - Administração</title>

<div class="window" style="margin-bottom: 20px;">
    <div class="window-header">
        <span>Gerenciar Imagem do Dia</span>
        <a href="/admin" style="text-decoration: none; color: var(--retro-header-text); font-size: 11px;">[ Voltar ao Painel ]</a>
    </div>
    <div class="window-content" style="padding: 10px;">
        <p style="margin: 0; color: gray; font-size: 12px;">Controle a fila de exibição e as molduras disponíveis do site.</p>
    </div>
</div>

<div style="display: flex; gap: 20px; align-items: flex-start;">
    <!-- Coluna Esquerda: Fila e Histórico -->
    <div style="flex: 2;">
        <!-- Fila de Imagens -->
        <div class="window" style="margin-bottom: 20px;">
            <div class="window-header">
                <span>Fila de Espera</span>
                <button id="ativarProximaBtn">Ativar Próxima</button>
            </div>
            <div class="window-content" style="padding: 2px; background: var(--retro-bg); height: 300px; overflow-y: auto; border: 2px inset var(--retro-border-dark);">
                <div id="fila-lista">
                    <div style="padding: 20px; text-align: center; color: gray;">Carregando fila...</div>
                </div>
            </div>
        </div>

        <!-- Histórico Recente -->
        <div class="window">
            <div class="window-header">Histórico Recente</div>
            <div class="window-content" style="padding: 2px; background: var(--retro-bg); height: 300px; overflow-y: auto; border: 2px inset var(--retro-border-dark);">
                <div id="historico-lista">
                    <div style="padding: 20px; text-align: center; color: gray;">Carregando histórico...</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Coluna Direita: Molduras -->
    <div style="flex: 1.3;">
        <div class="window">
            <div class="window-header">Molduras Padrão</div>
            <div class="window-content" style="padding: 10px;">
                <div id="molduras-lista" style="margin-bottom: 20px; background: var(--retro-bg); border: 2px inset var(--retro-border-dark); padding: 5px; height: 200px; overflow-y: auto;">
                    <div style="text-align: center; color: gray;">Carregando molduras...</div>
                </div>
                
                <hr style="border: 0; border-top: 1px dotted var(--retro-border-dark); margin: 15px 0;">
                
                <div style="font-weight: bold; margin-bottom: 10px;">Adicionar Nova Moldura</div>
                
                <form id="formNovaMoldura" style="margin: 0; display: flex; flex-direction: column; gap: 8px; background: var(--retro-bg); padding: 8px; border: 2px outset var(--retro-border-light);">
                    <div style="display: flex; flex-direction: column; gap: 2px;">
                        <label>Nome da Moldura:</label>
                        <input type="text" id="nomeMoldura" style="width: 100%; box-sizing: border-box;" required>
                    </div>
                    <div style="display: flex; flex-direction: column; gap: 2px;">
                        <label>Arquivo PNG ou GIF (Transparente):</label>
                        <input type="file" id="arquivoMoldura" accept="image/png, image/gif" style="width: 100%; box-sizing: border-box;" required>
                    </div>
                    <button type="submit" style="font-weight: bold; padding: 5px;">[ Fazer Upload ]</button>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
async function carregarFila() {
    const container = document.getElementById('fila-lista');
    try {
        const res = await fetch('/api/admin/imagemdodia/fila');
        const fila = await res.json();
        
        if (fila.length === 0) {
            container.innerHTML = '<div style="padding: 20px; text-align: center; color: gray;">Nenhuma imagem na fila.</div>';
            return;
        }

        const fragment = document.createDocumentFragment();

        fila.forEach(item => {
            const row = document.createElement("div");
            row.style.cssText = "border-bottom: 1px dashed var(--retro-border-light); padding: 8px; display: flex; align-items: center; justify-content: space-between; gap: 10px;";
            
            row.innerHTML = `
                <div style="display: flex; align-items: center; gap: 10px;">
                    <div style="position: relative; width: 60px; height: 60px; border: 2px inset var(--retro-border-dark); flex-shrink: 0;">
                        <img src="${item.url}" style="width: 100%; height: 100%; object-fit: cover;">
                        ${item.border ? `<img src="${item.border.url}" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none;">` : ''}
                    </div>
                    <div style="line-height: 1.2;">
                        <div style="font-weight: bold;">${item.text || 'Sem Título'}</div>
                        <small style="color: gray;">
                            Sugestão: ${item.requester ? item.requester.username : 'Sistema'}<br>
                            Em: ${item.createdat && !isNaN(new Date(item.createdat)) ? new Date(item.createdat).toLocaleDateString('pt-BR') : '---'}
                        </small>
                    </div>
                </div>
            `;
            
            const delBtn = document.createElement("button");
            delBtn.style.cssText = "color: red; font-weight: bold;";
            delBtn.textContent = "X";
            delBtn.onclick = (e) => {
                e.preventDefault();
                removerImagem(item.publicid, 'fila');
            };
            
            row.appendChild(delBtn);
            fragment.appendChild(row);
        });

        container.innerHTML = "";
        container.appendChild(fragment);
    } catch (err) {
        container.innerHTML = '<div style="padding: 20px; text-align: center; color: red;">Erro ao carregar fila.</div>';
    }
}

async function carregarHistorico() {
    const container = document.getElementById('historico-lista');
    try {
        const res = await fetch('/api/imagemdodia/ativas');
        const historico = await res.json();
        
        if (historico.length === 0) {
            container.innerHTML = '<div style="padding: 20px; text-align: center; color: gray;">Nenhuma imagem no histórico.</div>';
            return;
        }

        container.innerHTML = historico.slice(0, 10).map(item => `
            <div style="border-bottom: 1px dashed var(--retro-border-light); padding: 5px; display: flex; align-items: center; justify-content: space-between; gap: 10px;">
                <div style="display: flex; align-items: center; gap: 10px;">
                    <div style="position: relative; width: 40px; height: 40px; border: 1px inset var(--retro-border-dark); flex-shrink: 0;">
                        <img src="${item.url}" style="width: 100%; height: 100%; object-fit: cover;">
                        ${item.border ? `<img src="${item.border.url}" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none;">` : ''}
                    </div>
                    <div style="line-height: 1.2;">
                        <div style="font-weight: bold;">${item.text || 'Sem Título'}</div>
                        <small style="color: gray;">Ativada em: ${item.activatedat && !isNaN(new Date(item.activatedat)) ? new Date(item.activatedat).toLocaleDateString('pt-BR') : 'N/A'}</small>
                    </div>
                </div>
                <button onclick="removerImagem('${item.publicid}', 'historico')" style="color: red; font-size: 10px; cursor: pointer;">[Remover]</button>
            </div>
        `).join('');
    } catch (err) {
        container.innerHTML = '<div style="padding: 20px; text-align: center; color: red;">Erro ao carregar histórico.</div>';
    }
}

async function carregarMolduras() {
    const container = document.getElementById('molduras-lista');
    try {
        const res = await fetch('/api/imagemdodia/borders');
        const borders = await res.json();
        
        if (borders.length === 0) {
            container.innerHTML = '<div style="text-align: center; color: gray; padding: 10px;">Nenhuma moldura.</div>';
            return;
        }

        container.innerHTML = borders.map(b => `
            <div style="border-bottom: 1px dotted #ccc; padding: 5px; display: flex; align-items: center; justify-content: space-between; gap: 10px;">
                <div style="display: flex; align-items: center; gap: 10px;">
                    <img src="${b.url}" style="width: 40px; height: 40px; border: 1px inset var(--retro-border-dark); flex-shrink: 0;">
                    <span style="font-size: 12px; font-weight: bold;">${b.name}</span>
                </div>
                <button onclick="removerMoldura('${b.publicid}')" style="color: red; font-size: 10px; cursor: pointer;">[Remover]</button>
            </div>
        `).join('');
    } catch (err) {
        container.innerHTML = '<p style="color: red; text-align: center;">Erro ao carregar molduras.</p>';
    }
}

// ==================== EVENTOS ====================

document.getElementById('ativarProximaBtn').onclick = async () => {
    try {
        const res = await fetch('/api/admin/imagemdodia/next', {
            method: 'POST'
        });
        if (res.ok) {
            alert("Próxima imagem ativada!");
            carregarFila();
            carregarHistorico();
        } else {
            const data = await res.json();
            alert(data.message || "Erro ao ativar.");
        }
    } catch (err) {
        alert("Erro de conexão.");
    }
};

async function removerImagem(id, tipo) {
    const confirmado = await confirm(`Remover esta imagem da ${tipo === 'fila' ? 'fila' : 'histórico'}?`);
    if (!confirmado) return;

    try {
        const res = await fetch(`/api/admin/imagemdodia/${id}`, {
            method: 'DELETE'
        });
        if (res.ok) {
            if (tipo === 'fila') carregarFila();
            else carregarHistorico();
        }
        else {
            const data = await res.json();
            alert("Erro ao remover: " + (data.message || "Erro desconhecido"));
        }
    } catch (err) {
        alert("Erro de conexão.");
    }
}

async function removerMoldura(id) {
    const confirmado = await confirm("Remover esta moldura?");
    if (!confirmado) return;

    try {
        const res = await fetch(`/api/admin/imagemdodia/borders/${id}`, {
            method: 'DELETE'
        });
        if (res.ok) carregarMolduras();
        else alert("Erro ao remover moldura.");
    } catch (err) {
        alert("Erro de conexão.");
    }
}

document.getElementById('formNovaMoldura').onsubmit = async (e) => {
    e.preventDefault();

    const formData = new FormData();
    formData.append('file', document.getElementById('arquivoMoldura').files[0]);
    formData.append('nome', document.getElementById('nomeMoldura').value);

    try {
        const res = await fetch('/api/admin/imagemdodia/borders', {
            method: 'POST',
            body: formData
        });
        if (res.ok) {
            alert("Moldura adicionada!");
            document.getElementById('formNovaMoldura').reset();
            carregarMolduras();
        } else {
            alert("Erro ao enviar moldura.");
        }
    } catch (err) {
        alert("Erro de conexão.");
    }
};

// ==================== START ====================
carregarFila();
carregarHistorico();
carregarMolduras();
</script>
