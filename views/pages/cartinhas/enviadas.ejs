<link rel="stylesheet" href="/styles/commons/cartinhas-modals.css">
<script src="/js/commons/cartinhas-common.js"></script>

<article class="window">
    <header class="window-header">
        <span>Cartinhas Enviadas</span>
        <nav style="float: right;">
            <a href="/cartinhas" style="color: white; text-decoration: none; font-size: 10px;">[Voltar]</a>
        </nav>
    </header>
    <section class="window-content">
        <div id="loading" style="text-align: center; padding: 20px;">
            <p>Carregando histórico...</p>
        </div>

        <div id="cartinhas-container" style="display: none;">    
            <div id="cartas-grid"></div>
        </div>
        
        <div id="sem-cartinhas" style="display: none; text-align: center; padding: 20px;">
            <p>Você ainda não enviou nada...</p>
            <a href="/cartinhas/escrever">Escrever agora</a>
        </div>
    </section>
</article>

<script>
    window.tipoCartinhas = 'enviadas';
    let dataCache = [];

    async function carregarCartinhas(page = 1) {
        window.currentPage = page;
        const l = document.getElementById('loading');
        const container = document.getElementById('cartinhas-container');
        const empty = document.getElementById('sem-cartinhas');

        try {
            const res = await fetch(`/api/cartinhas/enviadas?page=${page}`, { credentials: 'include' });
            if (!res.ok) throw new Error();
            const dataResponse = await res.json();
            dataCache = dataResponse.data || [];
            l.style.display = 'none';

            if (dataCache.length === 0 && page === 1) {
                empty.style.display = 'block';
                container.style.display = 'none';
                return;
            }

            empty.style.display = 'none';
            container.style.display = 'block';

            renderizarGridCartinhas(dataResponse, '#cartas-grid', {
                abrirCartinha: (id) => {
                    const c = encontrarCartinha(id, dataCache), u = encontrarUsuarioPorCartinha(id, dataCache);
                    if (!c || !u) return;
                    window.usuarioCacheEdicao = u; // Cache para voltar da edição

                    window.modalCartinha.abrir({
                        tipo: 'enviadas', cartinha: c, usuario: u,
                        acoes: [
                            { label: 'Excluir', callback: () => confirmDel(id) },
                            { label: 'Editar', callback: () => {
                                window.modalCartinha.abrirEdicao(c, async (novoTitulo, novoConteudo) => {
                                    try {
                                        const res = await fetch(`/api/cartinhas/${id}`, {
                                            method: 'PUT', headers: { 'Content-Type': 'application/json' },
                                            credentials: 'include', body: JSON.stringify({ title: novoTitulo, body: novoConteudo })
                                        });
                                        if (res.ok) {
                                            window.modalCartinha.fechar();
                                            carregarCartinhas();
                                        }
                                    } catch (e) { alert('Erro ao salvar'); }
                                });
                            }}
                        ]
                    });
                }
            });
        } catch (e) {
            l.innerHTML = '<div style="color: red; text-align: center;">Erro ao carregar mensagens.</div>';
        }
    }

    async function confirmDel(id) {
        if (!await window.confirmRetro('Excluir esta enviada permanentemente?')) return;
        try {
            const res = await fetch(`/api/cartinhas/${id}`, { method: 'DELETE', credentials: 'include' });
            if (res.ok) { 
                window.modalCartinha.fechar();
                carregarCartinhas();
            }
        } catch (e) { alert('Erro ao excluir'); }
    }

    document.addEventListener('DOMContentLoaded', carregarCartinhas);
</script>
