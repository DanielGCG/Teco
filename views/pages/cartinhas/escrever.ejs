<link rel="stylesheet" href="/styles/commons/cartinhas-modals.css">
<script src="/js/commons/cartinhas-common.js"></script>

<div class="window" style="max-width: 600px; margin: 0 auto;">
    <div class="window-header">
        <span>Escrever Cartinha</span>
        <div style="float: right;">
            <a href="/cartinhas" style="color: white; text-decoration: none; font-size: 10px;">[Voltar]</a>
        </div>
    </div>
    <div class="window-content" style="background: var(--retro-bg);">
        <div style="margin-bottom: 10px; display: flex; justify-content: space-between;">
            <span style="font-size: 11px;">De: <b id="nomeRemetente">...</b></span>
            <button type="button" id="btnGerenciarRascunhos" style="font-size: 10px;">Meus Rascunhos</button>
        </div>

        <form id="formCartinha">
            <div style="margin-bottom: 10px; position: relative;">
                <label style="font-size: 11px; font-weight: bold;">Para:</label><br>
                <input type="text" id="destinatario" placeholder="Digite o nome do usuário..." autocomplete="off" style="width: 100%; box-sizing: border-box;">
                <input type="hidden" id="destinatarioId">
                <div id="sugestoesUsuarios" class="window" style="display: none; position: absolute; width: 100%; z-index: 100; max-height: 150px; overflow-y: auto; background: white;"></div>
            </div>

            <div style="margin-bottom: 10px;">
                <label style="font-size: 11px; font-weight: bold;">Assunto:</label>
                <span id="cnt-t" style="float: right; font-size: 10px; color: #666;">0/160</span><br>
                <input type="text" id="titulo" maxlength="160" style="width: 100%; box-sizing: border-box;">
            </div>

            <div style="margin-bottom: 15px;">
                <label style="font-size: 11px; font-weight: bold;">Mensagem:</label>
                <span id="cnt-c" style="float: right; font-size: 10px; color: #666;">0/2000</span><br>
                <textarea id="conteudo" rows="8" maxlength="2000" style="width: 100%; box-sizing: border-box; resize: vertical;"></textarea>
            </div>

            <div style="display: flex; gap: 5px; justify-content: flex-end;">
                <button type="button" id="btnLimpar">Limpar</button>
                <button type="button" id="btnSalvarRascunho">Salvar Rascunho</button>
                <button type="button" id="btnEnviar" style="font-weight: bold;">ENVIAR</button>
            </div>
        </form>
    </div>
</div>

<!-- Modal Rascunhos -->
<div id="modalRascunhosRetro" class="window" style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 10001; min-width: 300px; box-shadow: 2px 2px 10px rgba(0,0,0,0.5);">
    <div class="window-header">
        <span>Rascunhos</span>
        <button onclick="document.getElementById('modalRascunhosRetro').style.display='none'" style="float: right; padding: 0 4px;">X</button>
    </div>
    <div class="window-content" style="background: white; max-height: 300px; overflow-y: auto; padding: 0;">
        <div id="gradeRascunhos"></div>
    </div>
</div>
<div id="overlayRetroMsg" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.3); z-index: 10000;"></div>

<script>
    const composer = {
        dest: null,
        me: null,
        el: {
            bus: document.getElementById('destinatario'),
            id: document.getElementById('destinatarioId'),
            tit: document.getElementById('titulo'),
            con: document.getElementById('conteudo'),
            sug: document.getElementById('sugestoesUsuarios')
        },

        async init() {
            const res = await fetch('/api/users/me');
            if (res.ok) {
                this.me = await res.json();
                document.getElementById('nomeRemetente').textContent = this.me.username;
            }
            this.bind();
            this.checkURL();
            this.load();
        },

        bind() {
            this.el.bus.oninput = UIUtils.debounce(() => this.search(this.el.bus.value), 300);
            this.el.tit.oninput = this.el.con.oninput = () => this.update();
            document.getElementById('btnGerenciarRascunhos').onclick = () => this.list();
            document.getElementById('btnSalvarRascunho').onclick = () => this.save();
            document.getElementById('btnLimpar').onclick = () => this.clear();
            document.getElementById('btnEnviar').onclick = () => this.send();
            document.onclick = e => !e.target.closest('.position-relative') && (this.el.sug.style.display = 'none');
        },

        checkURL() {
            const p = new URLSearchParams(location.search);
            if (p.get('para')) this.select({ publicid: p.get('para'), username: decodeURIComponent(p.get('nome')) });
        },

        async search(q) {
            if (!q) return this.el.sug.style.display = 'none';
            const res = await fetch(`/api/users/buscar?limit=20&q=${encodeURIComponent(q)}`);
            const data = await res.json();
            const users = (data.usuarios || []).filter(u => u.username !== this.me?.username);
            
            this.el.sug.innerHTML = users.map(u => `
                <div style="padding: 5px; border-bottom: 1px solid #eee; cursor: pointer; font-size: 11px;" onclick="composer.select({publicid:'${u.publicid}',username:'${u.username}'})">
                    <img src="${u.profileimage}" style="vertical-align: middle; width: 20px; height: 20px; margin-right: 5px; border: 1px solid #ccc;">
                    <b>${u.username}</b>
                </div>
            `).join('') || '<div style="padding: 10px; font-size: 11px; color: #666;">Nenhum usuário...</div>';
            this.el.sug.style.display = 'block';
        },

        select(u) {
            this.dest = u;
            this.el.id.value = u.publicid;
            this.el.bus.value = u.username;
            this.el.sug.style.display = 'none';
        },

        update() {
            const t = this.el.tit.value.length, c = this.el.con.value.length;
            document.getElementById('cnt-t').textContent = t + '/160';
            document.getElementById('cnt-c').textContent = c + '/2000';
            localStorage.setItem('cartinha_tmp', JSON.stringify({t:this.el.tit.value, c:this.el.con.value, d:this.dest}));
        },

        load() {
            const r = JSON.parse(localStorage.getItem('cartinha_tmp') || '{}');
            if (r.t) this.el.tit.value = r.t;
            if (r.c) this.el.con.value = r.c;
            if (r.d) this.select(r.d);
            this.update();
        },

        save() {
            if (!this.el.tit.value && !this.el.con.value) return;
            const rList = JSON.parse(localStorage.getItem('cartinha_rascunhos') || '[]');
            rList.push({ id: Date.now(), t: this.el.tit.value, c: this.el.con.value, d: this.dest, ts: Date.now() });
            localStorage.setItem('cartinha_rascunhos', JSON.stringify(rList));
            alert('Rascunho salvo!');
        },

        list() {
            const rList = JSON.parse(localStorage.getItem('cartinha_rascunhos') || '[]');
            const container = document.getElementById('gradeRascunhos');
            container.innerHTML = rList.map(x => `
                <div style="display: flex; justify-content: space-between; align-items: center; padding: 5px; border-bottom: 1px solid #eee;">
                    <div style="cursor:pointer; flex-grow: 1;" onclick="composer.apply(${x.id})">
                        <div style="font-size: 11px; font-weight: bold;">${x.t || '(Sem assunto)'}</div>
                        <div style="font-size: 10px; color: #666;">Para: ${x.d ? x.d.username : '??'}</div>
                    </div>
                    <button style="padding: 0 4px; color: red;" onclick="composer.delR(${x.id})">X</button>
                </div>
            `).join('') || '<p style="text-align: center; padding: 10px; font-size: 11px;">Nenhum rascunho</p>';
            
            document.getElementById('modalRascunhosRetro').style.display = 'block';
            document.getElementById('overlayRetroMsg').style.display = 'block';
        },

        apply(id) {
            const r = JSON.parse(localStorage.getItem('cartinha_rascunhos') || '[]').find(x => x.id === id);
            if (r) { this.el.tit.value = r.t; this.el.con.value = r.c; if(r.d) this.select(r.d); this.update(); }
            document.getElementById('modalRascunhosRetro').style.display = 'none';
            document.getElementById('overlayRetroMsg').style.display = 'none';
        },

        delR(id) {
            let rList = JSON.parse(localStorage.getItem('cartinha_rascunhos') || '[]');
            localStorage.setItem('cartinha_rascunhos', JSON.stringify(rList.filter(x => x.id !== id)));
            this.list();
        },

        async clear() {
            if (!await window.confirmRetro('Limpar campos?', 'Aviso')) return;
            this.el.tit.value = this.el.con.value = this.el.bus.value = this.el.id.value = '';
            this.dest = null;
            localStorage.removeItem('cartinha_tmp');
            this.update();
        },

        async send() {
            if (!this.dest || !this.el.tit.value || !this.el.con.value) return alert('Preencha todos os campos!');
            const btn = document.getElementById('btnEnviar');
            btn.disabled = true;
            try {
                const res = await fetch('/api/cartinhas', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ recipientusername: this.dest.username, title: this.el.tit.value, body: this.el.con.value })
                });
                if (res.ok) {
                    alert('Cartinha enviada com sucesso!');
                    localStorage.removeItem('cartinha_tmp');
                    location.href = '/cartinhas';
                } else {
                    const err = await res.json();
                    alert(err.message || 'Erro ao enviar');
                }
            } catch (e) { alert('Erro técnico de conexão'); }
            finally { btn.disabled = false; }
        }
    };
    composer.init();

    // Fechar overlays ao clicar neles
    document.getElementById('overlayRetroMsg').onclick = () => {
        document.getElementById('modalRascunhosRetro').style.display = 'none';
        document.getElementById('overlayRetroMsg').style.display = 'none';
    };
</script>
