<link rel="stylesheet" href="/styles/commons/cartinhas-modals.css">
<script src="/js/commons/cartinhas-common.js"></script>

<div class="container py-4">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <a href="/cartinhas" class="btn btn-sm btn-outline-secondary border-0">
            <i class="bi bi-arrow-left me-1"></i> Voltar
        </a>
        <button type="button" class="btn btn-sm btn-outline-primary border-0" id="btnGerenciarRascunhos">
            <i class="bi bi-journal-text me-1"></i> Meus Rascunhos
        </button>
    </div>

    <div class="mx-auto" style="max-width: 700px;">
        <div class="card border-0 shadow-sm overflow-hidden">
            <div class="card-header border-0 pt-4 px-4">
                <h5 class="mb-0 fw-bold">Escrever Cartinha</h5>
                <p class="text-muted small mb-0">Envie uma mensagem especial para um amigo</p>
            </div>
            
            <div class="card-body p-4">
                <form id="formCartinha">
                    <div class="mb-4 position-relative">
                        <label class="form-label small fw-bold text-muted">Para:</label>
                        <div class="input-group input-group-sm">
                            <span class="input-group-text bg-light border-0"><i class="bi bi-person text-muted"></i></span>
                            <input type="text" class="form-control border-0 bg-light" id="destinatario" placeholder="Nome do usuário..." autocomplete="off">
                            <input type="hidden" id="destinatarioId">
                        </div>
                        <div id="sugestoesUsuarios" class="sugestoes-usuarios shadow-sm border-0 rounded-3 mt-1 overflow-hidden" style="display: none; position: absolute; z-index: 1000; width: 100%; background: white;"></div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted">Assunto:</label>
                        <input type="text" class="form-control form-control-sm border-0 bg-light" id="titulo" maxlength="160" placeholder="Título da sua cartinha">
                        <div class="text-end mt-1"><small class="text-muted" id="cnt-t">0/160</small></div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label small fw-bold text-muted">Mensagem:</label>
                        <textarea class="form-control border-0 bg-light" id="conteudo" maxlength="2000" rows="8" placeholder="Escreva aqui seu sentimento..."></textarea>
                        <div class="d-flex justify-content-between mt-1">
                            <small class="text-muted italic">Atenciosamente, <span id="nomeRemetente" class="fw-bold">...</span></small>
                            <small class="text-muted" id="cnt-c">0/2000</small>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-sm btn-light text-muted" id="btnSalvarRascunho" title="Salvar Rascunho">
                            <i class="bi bi-bookmark"></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-light text-danger" id="btnLimpar" title="Limpar tudo">
                            <i class="bi bi-trash"></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-primary ms-auto px-4" id="btnEnviar">
                            Enviar <i class="bi bi-send-fill ms-1"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalListaRascunhos" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold">Rascunhos</h6>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="gradeRascunhos" class="list-group list-group-flush"></div>
            </div>
        </div>
    </div>
</div>

<script>
    const composer = {
        dest: null,
        me: null,
        el: {
            bus: document.getElementById('destinatario'),
            id: document.getElementById('destinatarioId'),
            tit: document.getElementById('titulo'),
            con: document.getElementById('conteudo'),
            sug: document.getElementById('sugestoesUsuarios')
        },

        async init() {
            const res = await fetch('/api/users/me');
            if (res.ok) {
                this.me = await res.json();
                document.getElementById('nomeRemetente').textContent = this.me.username;
            }
            this.bind();
            this.checkURL();
            this.load();
        },

        bind() {
            this.el.bus.oninput = UIUtils.debounce(() => this.search(this.el.bus.value), 300);
            this.el.tit.oninput = this.el.con.oninput = () => this.update();
            document.getElementById('btnGerenciarRascunhos').onclick = () => this.list();
            document.getElementById('btnSalvarRascunho').onclick = () => this.save();
            document.getElementById('btnLimpar').onclick = () => this.clear();
            document.getElementById('btnEnviar').onclick = () => this.send();
            document.onclick = e => !e.target.closest('.position-relative') && (this.el.sug.style.display = 'none');
        },

        checkURL() {
            const p = new URLSearchParams(location.search);
            if (p.get('para')) this.select({ publicid: p.get('para'), username: decodeURIComponent(p.get('nome')) });
        },

        async search(q) {
            if (!q) return this.el.sug.style.display = 'none';
            
            const res = await fetch(`/api/users/buscar?limit=20&q=${encodeURIComponent(q)}`);
            const data = await res.json();
            const users = (data.usuarios || []).filter(u => u.username !== this.me?.username);
            this.el.sug.innerHTML = users.map(u => `
                <div class="p-2 border-bottom small hover-bg" style="cursor:pointer" onclick="composer.select({publicid:'${u.publicid}',username:'${u.username}'})">
                    <img src="${u.profileimage}" class="rounded-circle me-2" width="24" height="24"><b>${u.username}</b>
                </div>
            `).join('') || '<div class="p-3 text-muted small">Nenhum usuário...</div>';
            this.el.sug.style.display = 'block';
        },

        select(u) {
            this.dest = u;
            this.el.id.value = u.publicid;
            this.el.bus.value = u.username;
            this.el.sug.style.display = 'none';
        },

        update() {
            const t = this.el.tit.value.length, c = this.el.con.value.length;
            document.getElementById('cnt-t').textContent = t + '/160';
            document.getElementById('cnt-c').textContent = c + '/2000';
            localStorage.setItem('cartinha_tmp', JSON.stringify({t:this.el.tit.value, c:this.el.con.value, d:this.dest}));
        },

        load() {
            const r = JSON.parse(localStorage.getItem('cartinha_tmp') || '{}');
            if (r.t) this.el.tit.value = r.t;
            if (r.c) this.el.con.value = r.c;
            if (r.d) this.select(r.d);
            this.update();
        },

        save() {
            if (!this.el.tit.value && !this.el.con.value) return;
            const rList = JSON.parse(localStorage.getItem('cartinha_rascunhos') || '[]');
            rList.push({ id: Date.now(), t: this.el.tit.value, c: this.el.con.value, d: this.dest, ts: Date.now() });
            localStorage.setItem('cartinha_rascunhos', JSON.stringify(rList));
            mostrarFeedback('Rascunho salvo!');
        },

        list() {
            const rList = JSON.parse(localStorage.getItem('cartinha_rascunhos') || '[]');
            const container = document.getElementById('gradeRascunhos');
            container.innerHTML = rList.map(x => `
                <div class="list-group-item d-flex justify-content-between align-items-center border-0 px-0">
                    <div style="cursor:pointer" onclick="composer.apply(${x.id})">
                        <div class="fw-bold small text-truncate" style="max-width:200px">${x.t || '(Sem título)'}</div>
                        <div class="text-muted" style="font-size:0.7rem">Para: ${x.d?.username || '?'}</div>
                    </div>
                    <button class="btn btn-sm text-danger" onclick="composer.delR(${x.id})"><i class="bi bi-trash"></i></button>
                </div>
            `).join('') || '<p class="text-center text-muted py-3">Nenhum rascunho</p>';
            new bootstrap.Modal(document.getElementById('modalListaRascunhos')).show();
        },

        apply(id) {
            const r = JSON.parse(localStorage.getItem('cartinha_rascunhos') || '[]').find(x => x.id === id);
            if (r) { this.el.tit.value = r.t; this.el.con.value = r.c; if(r.d) this.select(r.d); this.update(); }
            const mod = bootstrap.Modal.getInstance(document.getElementById('modalListaRascunhos'));
            if (mod) mod.hide();
        },

        delR(id) {
            let rList = JSON.parse(localStorage.getItem('cartinha_rascunhos') || '[]');
            localStorage.setItem('cartinha_rascunhos', JSON.stringify(rList.filter(x => x.id !== id)));
            this.list();
        },

        async clear() {
            if (!confirm('Limpar campos?')) return;
            this.el.tit.value = this.el.con.value = this.el.bus.value = this.el.id.value = '';
            this.dest = null;
            localStorage.removeItem('cartinha_tmp');
            this.update();
        },

        async send() {
            if (!this.dest || !this.el.tit.value || !this.el.con.value) return mostrarFeedback('Preencha tudo', 'warning');
            const btn = document.getElementById('btnEnviar');
            btn.disabled = true;
            try {
                const res = await fetch('/api/cartinhas', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ recipientusername: this.dest.username, title: this.el.tit.value, body: this.el.con.value })
                });
                if (res.ok) {
                    mostrarFeedback('Enviada!');
                    localStorage.removeItem('cartinha_tmp');
                    location.href = '/cartinhas';
                } else {
                    const err = await res.json();
                    mostrarFeedback(err.message, 'danger');
                }
            } catch (e) { mostrarFeedback('Erro técnico', 'danger'); }
            finally { btn.disabled = false; }
        }
    };
    composer.init();
</script>

<style>
    .hover-bg:hover { background-color: #f8f9fa; }
    .textarea-cartinha:focus { box-shadow: none !important; }
</style>

<%- include('../../utils/modal-confirmacao') %>
