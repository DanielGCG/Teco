<link rel="stylesheet" href="/styles/commons/cartinhas-modals.css">
<script src="/js/commons/cartinhas-common.js"></script>

<article class="window">
    <header class="window-header">
        <span>Cartinhas Favoritas</span>
        <nav style="float: right;">
            <a href="/cartinhas" style="color: white; text-decoration: none; font-size: 10px;">[Voltar]</a>
        </nav>
    </header>
    <section class="window-content">
        <div id="loading" style="text-align: center; padding: 20px;">
            <p>Carregando seus tesouros...</p>
        </div>

        <div id="cartinhas-container" style="display: none;">
            <div id="cartas-grid"></div>
        </div>

        <div id="sem-cartinhas" style="display: none; text-align: center; padding: 20px;">
            <p>Nenhuma cartinha favoritada...</p>
        </div>
    </section>
</article>

<script>
window.tipoCartinhas = 'favoritas';
let dataCache = [];

async function carregarCartinhas(page = 1) {
    window.currentPage = page;
    const l = document.getElementById('loading');
    const container = document.getElementById('cartinhas-container');
    const empty = document.getElementById('sem-cartinhas');

    try {
        const res = await fetch(`/api/cartinhas/favoritas?page=${page}`, { credentials: 'include' });
        if (!res.ok) throw new Error();
        const dataResponse = await res.json();
        const raw = dataResponse.data || [];
        
        const grouped = {};
        raw.forEach(c => {
            const rid = c.remetente?.publicid || 'anon';
            if (!grouped[rid]) grouped[rid] = { ...c.remetente, userId: rid, cartinhas: [] };
            grouped[rid].cartinhas.push(c);
        });
        
        dataCache = Object.values(grouped);
        l.style.display = 'none';

        if (dataCache.length === 0 && page === 1) {
            empty.style.display = 'block';
            container.style.display = 'none';
            return;
        }

        empty.style.display = 'none';
        container.style.display = 'block';

        // Reconstruindo objeto paginado com data agrupado
        const paginatedResponse = { ...dataResponse, data: dataCache };

        renderizarGridCartinhas(paginatedResponse, '#cartas-grid', {
            abrirCartinha: (id) => {
                const c = encontrarCartinha(id, dataCache), u = encontrarUsuarioPorCartinha(id, dataCache);
                if (!c || !u) return;

                window.modalCartinha.abrir({
                    tipo: 'favoritas', cartinha: c, usuario: u,
                    acoes: [
                        { label: 'Responder', classe: 'btn-primary', callback: () => location.href=`/cartinhas/escrever?para=${u.userId}&nome=${u.username}` },
                        { label: 'Remover Favorito', classe: 'btn-warning', callback: () => toggleFav(id) },
                        { label: 'Excluir', classe: 'btn-outline-danger', callback: () => confirmDel(id) }
                    ]
                });
            }
        });
    } catch (e) {
        l.innerHTML = '<div style="color: red; text-align: center;">Erro ao carregar favoritas.</div>';
    }
}

async function toggleFav(id) {
    if (!await window.confirmRetro('Desfavoritar esta mensagem?')) return;
    await toggleFavoritoCommon(id, dataCache);
    window.modalCartinha.fechar();
    carregarCartinhas();
}

async function confirmDel(id) {
    if (!await window.confirmRetro('Excluir esta favorita permanentemente?')) return;
    try {
        await fetch(`/api/cartinhas/${id}`, { method: 'DELETE', credentials: 'include' });
        window.modalCartinha.fechar();
        carregarCartinhas();
    } catch (e) { alert('Erro ao excluir'); }
}

document.addEventListener('DOMContentLoaded', carregarCartinhas);
</script>
