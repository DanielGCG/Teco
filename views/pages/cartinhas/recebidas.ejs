<link rel="stylesheet" href="/styles/commons/cartinhas-modals.css">
<script src="/js/commons/cartinhas-common.js"></script>

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="h4 fw-bold mb-0">Caixa de Entrada</h2>
        <a href="/cartinhas" class="btn btn-sm btn-outline-secondary border-0">
            <i class="bi bi-arrow-left me-1"></i> Voltar
        </a>
    </div>

    <div id="loading" class="text-center py-5">
        <div class="spinner-border text-primary" role="status"></div>
    </div>

    <div id="cartinhas-container" style="display: none;">
        <div id="cartas-grid"></div>
    </div>

    <div id="sem-cartinhas" class="text-center py-5" style="display: none;">
        <div class="display-1 text-muted mb-3 opacity-25"><i class="bi bi-mailbox"></i></div>
        <p class="text-muted">Caixa de entrada vazia...</p>
    </div>
</div>

<script>
window.tipoCartinhas = 'recebidas';
let dataCache = [];

async function carregarCartinhas() {
    const l = document.getElementById('loading');
    try {
        const res = await fetch('/api/cartinhas/recebidas', { credentials: 'include' });
        if (!res.ok) throw new Error();
        dataCache = await res.json();
        l.style.display = 'none';

        renderizarGridCartinhas(dataCache, '#cartas-grid', {
            abrirCartinha: async (id) => {
                const c = encontrarCartinha(id, dataCache), u = encontrarUsuarioPorCartinha(id, dataCache);
                if (!c || !u) return;

                if (!c.isread) fetch(`/api/cartinhas/${id}/lida`, { method: 'PUT', credentials: 'include' });

                window.modalCartinha.abrir({
                    tipo: 'recebidas', cartinha: c, usuario: u,
                    acoes: [
                        { label: 'Responder', classe: 'btn-primary', callback: () => location.href=`/cartinhas/escrever?para=${u.userId}&nome=${u.username}` },
                        { label: c.isfavorited ? 'Desfavoritar' : 'Favoritar', classe: c.isfavorited ? 'btn-warning' : 'btn-outline-warning', callback: () => toggleFav(id) },
                        { label: 'Excluir', classe: 'btn-outline-danger', callback: () => confirmDel(id) }
                    ]
                });
                c.isread = true;
            }
        });
    } catch (e) {
        l.innerHTML = '<div class="alert alert-danger mx-auto" style="max-width:400px">Erro ao carregar mensagens.</div>';
    }
}

async function toggleFav(id) {
    await toggleFavoritoCommon(id, dataCache);
    window.modalCartinha.fechar();
    carregarCartinhas();
}

async function confirmDel(id) {
    if (!confirm('Excluir esta mensagem?')) return;
    try {
        await fetch(`/api/cartinhas/${id}`, { method: 'DELETE', credentials: 'include' });
        window.modalCartinha.fechar();
        carregarCartinhas();
        mostrarFeedback('Excluída!');
    } catch (e) { mostrarFeedback('Erro', 'danger'); }
}

document.addEventListener('DOMContentLoaded', carregarCartinhas);
</script>

<%- include('../../utils/modal-confirmacao') %>
