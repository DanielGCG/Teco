<link rel="stylesheet" href="/styles/commons/chat-dm-common.css">

<!-- Módulo de estilos centralizados para Chat e DMs -->

<div id="chats-container" class="chat-layout-container">
    <!-- Sidebar -->
    <div class="sidebar-retro" id="sidebar">
        <div class="window" style="height: 100%; display: flex; flex-direction: column; margin: 0;">
            <div class="window-header">
                <span>Salas Públicas</span>
            </div>
            <div class="window-content" style="flex-grow: 1; display: flex; flex-direction: column; padding: 5px;">
                <div style="margin-bottom: 5px; display: flex;">
                    <input type="text" id="search-chat-input" placeholder="Filtrar salas..." class="chat-textarea" style="height: 30px;">
                </div>
                <div id="chat-list" style="flex-grow: 1; overflow-y: auto; background: var(--retro-window-bg); border: 2px inset var(--retro-border-dark);">
                    <div style="text-align: center; padding: 10px;">
                        Carregando salas...
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Área de Chat -->
    <div class="chat-area-retro">
        <div class="window" id="chat-area" style="height: 100%; flex-direction: column; margin: 0; display: none;">
            <div class="window-header" style="display: flex; justify-content: space-between; align-items: center;">
                <span id="chat-title">Sala</span>
                <button onclick="voltarLista()" id="btn-voltar" class="btn-voltar-mobile">Voltar</button>
            </div>
            
            <div class="window-content" id="chat-messages" style="flex-grow: 1; overflow-y: auto; background: var(--retro-window-bg); border: 2px inset var(--retro-border-dark); margin: 5px; padding: 5px;">
                <!-- Mensagens aqui -->
            </div>

            <div class="window-content" style="border-top: none; padding: 0;">
                <div class="chat-input-area">
                    <textarea id="input-msg" class="chat-textarea" placeholder="Digite sua mensagem..."></textarea>
                    <button id="send-btn" class="chat-send-btn">Enviar</button>
                </div>
            </div>
        </div>

        <!-- Placeholder quando nada selecionado -->
        <div class="window" id="info-area" style="height: 100%; display: flex; flex-direction: column; margin: 0;">
            <div class="window-header">
                <span>Detalhes da Sala</span>
            </div>
            <div class="window-content" style="flex-grow: 1; display: flex; align-items: center; justify-content: center; text-align: center;">
                <div>
                    <h4>Selecione uma sala</h4>
                    <p>Escolha uma das salas ao lado para ver mais detalhes e entrar na conversa.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Módulos globais -->
<script src="/js/commons/chat-dm-common.js"></script>

<script>
    let socket = null;
    let allChats = [];
    let selectedChat = null;
    let currentUser = window.UserContext ? window.UserContext.get() : null;
    let allMessages = [];
    const bufferSize = 100;

    // Elementos do DOM (Resolvidos na inicialização)
    let chatMessages, inputMsg, sendBtn;

    // Inicialização
    document.addEventListener('DOMContentLoaded', async () => {
        chatMessages = document.getElementById('chat-messages');
        inputMsg = document.getElementById('input-msg');
        sendBtn = document.getElementById('send-btn');
        
        // Resolve o socket global
        socket = window.appSocket || (window.SocketConnector ? window.SocketConnector.getSocket() : null);

        ChatLayout.init({}); 
        ChatLayout.hideChat(); // Garante que o placeholder aparece primeiro
        
        if (socket) {
            setupSocketListeners();
        } else {
            console.warn('[Chats] Socket não disponível imediatamente, aguardando...');
            setTimeout(() => {
                socket = window.appSocket || (window.SocketConnector ? window.SocketConnector.getSocket() : null);
                if (socket) setupSocketListeners();
            }, 1000);
        }

        try {
            if (!currentUser) {
                const resUser = await fetch('/api/users/me', { credentials: 'include' });
                if (resUser.ok) currentUser = await resUser.json();
            }
            
            await carregarChats();

            // Se houver um chatName na URL (passado pelo backend ou histórico)
            const initialChatName = "<%= locals.chatName || '' %>" || window.location.pathname.split('/').pop();
            if (initialChatName && initialChatName !== 'chat') {
                const chat = allChats.find(c => c.title === initialChatName || c.publicid.toString() === initialChatName);
                if (chat) selecionarChat(chat);
            }
        } catch (err) {
            console.error('[Chats] Erro na inicialização:', err);
        }

        // Configura inputs
        if (inputMsg && sendBtn) {
            ChatUtils.setupMessageInput(inputMsg, sendBtn, (text) => {
                if (!selectedChat?.publicid || !socket) return;
                socket.emit('sendMessage', {
                    chatId: selectedChat.publicid,
                    mensagem: text,
                    type: 'chat'
                });
            });
        }

        const searchInput = document.getElementById('search-chat-input');
        if (searchInput) {
            searchInput.addEventListener('input', (e) => {
                const term = e.target.value.toLowerCase();
                const filtered = allChats.filter(c => (c.title || "").toLowerCase().includes(term));
                renderizarLista(filtered);
            });
        }
    });

    async function carregarChats() {
        try {
            const res = await fetch('/api/chats', { credentials: 'include' });
            allChats = await res.json();
            renderizarLista(allChats);
        } catch (error) {
            console.error('[Chats] Erro ao carregar:', error);
            const chatList = document.getElementById('chat-list');
            if (chatList) chatList.innerHTML = '<p class="text-danger text-center p-3">Erro ao carregar salas.</p>';
        }
    }

    function renderizarLista(chats) {
        const container = document.getElementById('chat-list');
        if (!container) return;
        
        container.innerHTML = '';

        if (chats.length === 0) {
            container.innerHTML = '<p class="text-muted text-center p-3">Nenhuma sala encontrada.</p>';
            return;
        }

        chats.forEach(chat => {
            const card = document.createElement('div');
            card.dataset.id = chat.publicid;
            card.className = `conversation-card chat-card ${selectedChat?.publicid === chat.publicid ? 'active' : ''}`;
            card.innerHTML = `
                <div style="display: flex; gap: 10px; align-items: center; width: 100%; padding: 0 10px;">
                    <div style="font-weight: bold; color: var(--retro-link); width: 15px; text-align: center;">#</div>
                    <div style="flex:1; min-width:0; display: flex; flex-direction: column; justify-content: center;">
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <strong style="white-space: nowrap; overflow: hidden; text-overflow: ellipsis; display: block; font-size: 14px;">${chat.title}</strong>
                            ${chat.unreadCount > 0 ? `<span class="unread-badge" style="background: red; color: white; border-radius: 5px; padding: 2px 5px; font-size: 10px;">${chat.unreadCount}</span>` : ''}
                        </div>
                        <small style="color: gray; display: block; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-size: 11px;">por ${chat.creatorusername}</small>
                    </div>
                </div>
            `;
            card.onclick = () => selecionarChat(chat);
            container.appendChild(card);
        });
    }

    function selecionarChat(chat) {
        if (selectedChat?.publicid === chat.publicid) return;
        
        selectedChat = chat;
        const chatNome = chat.title;
        chat.unreadCount = 0;
        renderizarLista(allChats);
        
        allMessages = [];
        if (chatMessages) chatMessages.innerHTML = '';
        
        // Atualiza URL sem recarregar
        window.history.pushState({}, '', `/chat/${chatNome}`);

        // UI
        document.querySelectorAll('.chat-card').forEach(c => {
            c.classList.toggle('active', c.dataset.id == chat.publicid);
        });

        ChatLayout.showChat(`# ${chatNome}`);

        // Socket
        if (socket) socket.emit('getMessages', { chatId: chat.publicid, page: 1, type: 'chat' });
    }

    function voltarLista() {
        ChatLayout.hideChat();
        selectedChat = null;
        window.history.pushState({}, '', '/chat');
    }

    function formatMessage(msg) {
        const user = currentUser || window.currentUser;
        const username = msg.author?.username || msg.username || 'Usuário';
        return {
            ...msg,
            username,
            isMine: user ? (username === user.username) : (msg.isMine || false),
            createdat: msg.createdat || new Date().toISOString()
        };
    }

    function setupSocketListeners() {
        if (!socket) return;

        socket.on('messagesLoaded', ({ chatId: loadedChatId, messages }) => {
            if (selectedChat && !selectedChat.publicid) selectedChat.publicid = loadedChatId;
            if (selectedChat?.publicid !== loadedChatId) return;

            allMessages = messages.map(msg => formatMessage(msg));
            ChatUtils.renderMessages(allMessages, chatMessages, { clearContainer: true, scrollToBottom: true });
            
            socket.emit('joinChat', loadedChatId);
            socket.emit('markAsRead', { chatId: loadedChatId });
        });

        socket.on('newMessage', ({ chatId, message }) => {
            const formatted = formatMessage(message);
            
            if (selectedChat?.publicid === chatId) {
                allMessages.push(formatted);
                ChatUtils.renderMessages([formatted], chatMessages, { clearContainer: false, scrollToBottom: true });
                
                if (chatMessages && chatMessages.children.length > bufferSize) {
                    chatMessages.removeChild(chatMessages.firstChild);
                }

                const myUser = currentUser || window.currentUser;
                if (myUser && formatted.username !== myUser.username) {
                    socket.emit('markAsRead', { chatId });
                }
            } else {
                const chat = allChats.find(c => c.publicid === chatId);
                const myUser = currentUser || window.currentUser;
                if (chat && myUser && formatted.username !== myUser.username) {
                    chat.unreadCount = (chat.unreadCount || 0) + 1;
                    renderizarLista(allChats);
                }
            }
        });
    }
</script>
