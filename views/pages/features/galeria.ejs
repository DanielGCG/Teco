<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/styles/galeria.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"></script>

<div class="window mt-3" id="conteudo-principal"
    data-gallery-id="<%= (typeof galleryId !== 'undefined') ? galleryId : '' %>"
    style="background: transparent; box-shadow: none; border: none;">
    <div class="window-header" style="height: auto; min-height: 18px; flex-wrap: wrap; gap: 5px; padding-bottom: 5px; padding-top: 5px;">
        <span class="window-title" id="gallery-title">Carregando...</span>
        <div style="display: flex; flex-wrap: wrap; gap: 5px; justify-content: flex-end;">
            <button class="window-btn" onclick="GaleriaManager.copiarLink()">Copiar Link</button>
            <button class="window-btn" onclick="GaleriaManager.exportarImagem()">Exportar Imagem</button>
            <button class="window-btn" onclick="GaleriaManager.openUploadModal()">+ Adicionar Mídia</button>
            <button class="window-btn" id="btn-edit-mode" onclick="GaleriaManager.toggleEditMode()">Editar Layout</button>
            <button class="window-btn" id="btn-save-layout" onclick="GaleriaManager.saveLayout()" style="display: none;">Salvar Layout</button>
            <button class="window-btn" onclick="GaleriaManager.openConfigModal()">Configurações</button>
        </div>
    </div>
    <div class="window-content" style="background: transparent; border: none; position: relative; padding: 0">
        <div style="position: absolute; top: 10px; left: 10px; z-index: 1000; background: rgba(255, 255, 255, 0.5); backdrop-filter: blur(4px); padding: 5px 10px; border-radius: 8px; pointer-events: none;">
            <p id="gallery-description" style="margin-top: 0; margin-bottom: 5px; opacity: 0.9; font-weight: 500; display: none;"></p>
            <small style="opacity: 0.9; font-weight: 500;">Criado por <strong id="gallery-author">...</strong></small>
        </div>

        <div id="image-list" style="margin-top: 0;">
            <div style="text-align: center; opacity: 0.8; padding: 20px;" class="grid-full-width">
                Carregando biblioteca...
            </div>
        </div>
    </div>

<!-- Modal Adicionar Mídia -->
<div id="modalUpload" class="window"
    style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1000; width: 400px; max-width: 95vw; box-sizing: border-box;">
    <div class="window-header">
        <span class="window-title">Adicionar Mídia</span>
        <button type="button" class="btn-micro"
            onclick="document.getElementById('modalUpload').style.display='none'; document.getElementById('modalBackdrop').style.display='none';"
            style="float: right;">[Fechar]</button>
    </div>
    <div class="window-content">
        <form id="formUpload" style="display: flex; flex-direction: column; gap: 10px;">
            <div style="display: flex; gap: 10px; margin-bottom: 5px; border-bottom: 1px solid var(--retro-border-dark); padding-bottom: 10px;">
                <label style="cursor: pointer;"><input type="radio" name="item_type" value="media" checked onchange="GaleriaManager.toggleUploadType()"> Mídia</label>
                <label style="cursor: pointer;"><input type="radio" name="item_type" value="text" onchange="GaleriaManager.toggleUploadType()"> Texto</label>
                <label style="cursor: pointer;"><input type="radio" name="item_type" value="link" onchange="GaleriaManager.toggleUploadType()"> Link</label>
            </div>

            <div id="upload-group-media">
                <label style="display: block; margin-bottom: 5px;">Arquivo</label>
                <input type="file" name="fileInput" id="upload-file-input" accept="image/*,video/*,audio/*,.mkv,.avi,.webp" required
                    style="width: 100%; box-sizing: border-box;">
            </div>

            <div id="upload-group-text" style="display: none;">
                <label style="display: block; margin-bottom: 5px;">Texto</label>
                <textarea name="text_content" id="upload-text-content" rows="4" style="width: 100%; box-sizing: border-box; resize: vertical;" placeholder="Digite seu texto aqui..."></textarea>
            </div>

            <div id="upload-group-link" style="display: none; flex-direction: column; gap: 10px;">
                <div>
                    <label style="display: block; margin-bottom: 5px;">URL do Link</label>
                    <input type="url" name="link_url" id="upload-link-url" placeholder="https://..." style="width: 100%; box-sizing: border-box;">
                </div>
                <div>
                    <label style="display: block; margin-bottom: 5px;">Capa do Link (Opcional)</label>
                    <input type="file" name="link_cover" id="upload-link-cover" accept="image/*" style="width: 100%; box-sizing: border-box;">
                </div>
            </div>

            <div>
                <label style="display: block; margin-bottom: 5px;">Nome / Legenda (Opcional)</label>
                <input type="text" name="title" id="upload-title" placeholder="Ex: Bora soltar a criatividade!"
                    style="width: 100%; box-sizing: border-box;">
            </div>
            <div id="upload-progress-wrapper"
                style="display:none; border: 1px solid gray; padding: 10px; margin-top: 5px; background: #eee;">
                <div style="display: flex; justify-content: space-between; margin-bottom: 5px;">
                    <strong>Enviando...</strong>
                    <span id="upload-percent-text">0%</span>
                </div>
                <div style="height: 10px; border: 1px solid gray; background: white; margin-bottom: 5px;">
                    <div id="upload-progress-bar" style="height: 100%; width: 0%; background: blue;"></div>
                </div>
                <div style="text-align: right; color: gray; font-size: 12px;">
                    <span id="upload-size-text">0.0 MB / 0.0 MB</span>
                </div>
            </div>
            <button type="submit" id="btn-submit-upload" class="btn-block btn-bold" style="margin-top: 10px; padding: 5px;">Enviar</button>
        </form>
    </div>
</div>

<!-- Modal Configurações -->
<div id="modalConfig" class="window"
    style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1000; width: 600px; max-width: 95vw; box-sizing: border-box;">
    <div class="window-header">
        <span class="window-title">Configurações</span>
        <button type="button" class="btn-micro"
            onclick="document.getElementById('modalConfig').style.display='none'; document.getElementById('modalBackdrop').style.display='none';"
            style="float: right;">[Fechar]</button>
    </div>
    <div class="window-content" style="max-height: 80vh; overflow-y: auto;">
        <form id="formConfig" style="display: flex; flex-direction: column; gap: 10px;">
            <input type="hidden" name="remove_cover" id="flag-remove-cover" value="false">
            <input type="hidden" name="remove_background" id="flag-remove-bg" value="false">

            <div style="display: flex; gap: 20px; flex-wrap: wrap;">
                <!-- Esquerda -->
                <fieldset style="flex: 1; min-width: 250px; display: flex; flex-direction: column; gap: 10px;">
                    <legend>Informações</legend>
                    <div>
                        <label style="display: block;">Nome</label>
                        <input type="text" name="name" id="config-name" required
                            style="width: 100%; box-sizing: border-box;">
                    </div>
                    <div>
                        <label style="display: block;">Descrição</label>
                        <textarea name="description" id="config-description" rows="3"
                            style="width: 100%; box-sizing: border-box; resize: vertical;"></textarea>
                    </div>
                    <div style="display: flex; align-items: center; gap: 5px;">
                        <input type="checkbox" name="ispublic" id="config-is-public">
                        <label for="config-is-public">Público</label>
                    </div>

                    <div id="collaborators-section" style="margin-top: 10px; position: relative;">
                        <label style="display: block; font-weight: bold;">Colaboradores</label>
                        <input type="text" id="search-user-input" placeholder="Buscar usuário..." style="width: 100%; box-sizing: border-box;" autocomplete="off" oninput="GaleriaManager.debouncedSearchUsers()">
                        <div id="search-results" class="window"
                            style="display: none; position: absolute; width: 100%; z-index: 100; max-height: 150px; overflow-y: auto; background: white; margin-top: 2px;">
                        </div>
                        <div id="collaborators-list"
                            style="display: flex; flex-wrap: wrap; gap: 5px; margin-top: 10px;"></div>
                    </div>
                </fieldset>

                <!-- Direita -->
                <fieldset style="flex: 1; min-width: 250px; display: flex; flex-direction: column; gap: 10px;">
                    <legend>Visual</legend>
                    <div>
                        <label style="display: block; font-size: 11px;">Capa</label>
                        <div style="display: flex; gap: 5px;">
                            <input type="file" name="cover" id="input-cover" accept="image/*" class="preview-trigger"
                                style="flex: 1; min-width: 0; box-sizing: border-box; overflow: hidden;">
                            <button type="button" onclick="GaleriaManager.toggleRemove('cover')" class="btn-micro">X</button>
                        </div>
                        <small id="status-cover" style="color: red; display: none;">Será removido ao salvar</small>
                    </div>
                    <div>
                        <label style="display: block; font-size: 11px;">Fundo</label>
                        <div style="display: flex; gap: 5px;">
                            <input type="file" name="background" id="input-bg" accept="image/*" class="preview-trigger"
                                style="flex: 1; min-width: 0; box-sizing: border-box; overflow: hidden;">
                            <button type="button" onclick="GaleriaManager.toggleRemove('background')" class="btn-micro">X</button>
                        </div>
                        <small id="status-bg" style="color: red; display: none;">Será removido ao salvar</small>
                    </div>
                    <div style="display: flex; gap: 10px;">
                        <div><label style="display: block; font-size: 11px;">Fundo</label><input type="color"
                                name="backgroundcolor" id="config-bg-color" class="preview-trigger"></div>
                        <div><label style="display: block; font-size: 11px;">Texto</label><input type="color"
                                name="fontcolor" id="config-font-color" class="preview-trigger"></div>
                        <div><label style="display: block; font-size: 11px;">Cartões</label><input type="color"
                                name="cardcolor" id="config-card-color" class="preview-trigger"></div>
                    </div>
                    <div>
                        <label style="display: block; font-size: 11px;">Colunas</label>
                        <select name="gridxsize" id="config-grid-columns" class="preview-trigger" style="width: 100%;">
                            <option value="12">12</option>
                            <option value="16" selected>16 (Padrão)</option>
                            <option value="20">20</option>
                            <option value="24">24</option>
                            <option value="32">32</option>
                        </select>
                    </div>
                    <div id="group-bg-fill">
                        <label style="display: block; font-size: 11px;">Preenchimento Fundo</label>
                        <select name="backgroundfill" id="config-bg-fill" class="preview-trigger" style="width: 100%;">
                            <option value="cover">Cobrir</option>
                            <option value="repeat">Repetir</option>
                        </select>
                    </div>
                    <div>
                        <label style="display: block; font-size: 11px;">Fonte (Google)</label>
                        <div style="display: flex; gap: 5px;">
                            <input type="text" name="fontfamily" id="config-font-family" class="preview-trigger"
                                placeholder="Ex: Roboto" style="flex: 1;">
                        </div>
                    </div>
                    </div>
                </fieldset>
            </div>

            <hr style="width: 100%; margin: 10px 0; border: none; border-top: 1px solid gray;">
            <footer style="display: flex; justify-content: space-between; flex-wrap: wrap; gap: 10px; padding-bottom: 5px; padding-inline: 5px;">
                <button type="button" onclick="GaleriaManager.deleteGallery()" style="color: red;" class="btn-sm">Excluir Galeria</button>
                <div style="display: flex; gap: 5px;">
                    <button type="button" class="btn-sm"
                        onclick="document.getElementById('modalConfig').style.display='none'; document.getElementById('modalBackdrop').style.display='none';">Cancelar</button>
                    <button type="submit" class="btn-sm btn-bold">Salvar</button>
                </div>
            </footer>
        </form>
    </div>
</div>

<!-- Modal Editar Item -->
<div id="modalEditItem" class="window"
    style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1000; width: 400px; max-width: 95vw; box-sizing: border-box;">
    <div class="window-header">
        <span class="window-title">Editar Item</span>
        <button type="button" class="window-btn"
            onclick="document.getElementById('modalEditItem').style.display='none'; document.getElementById('modalBackdrop').style.display='none';"
            style="float: right;">[Fechar]</button>
    </div>
    <div class="window-content">
        <form id="formEditItem" style="display: flex; flex-direction: column; gap: 10px;">
            <input type="hidden" name="item_id" id="edit-item-id">
            <input type="hidden" id="edit-flag-remove-cover" value="false">
            <div>
                <label style="display: block; margin-bottom: 5px;">Nome / Legenda</label>
                <input type="text" name="title" id="edit-item-name" style="width: 100%; box-sizing: border-box;">
            </div>
            <div id="edit-item-text-group" style="display: none;">
                <label style="display: block; margin-bottom: 5px;">Texto</label>
                <textarea name="textbody" id="edit-item-textbody" rows="4" style="width: 100%; box-sizing: border-box; resize: vertical;" placeholder="Edite seu texto aqui..."></textarea>
            </div>
            <div style="display: flex; align-items: center; gap: 5px;">
                <input type="checkbox" id="edit-item-showtitle" name="showtitle">
                <label for="edit-item-showtitle">Mostrar título</label>
            </div>
            <div>
                <label style="display: block; margin-bottom: 5px;">Ajuste de Imagem</label>
                <select name="objectfit" id="edit-item-fit" style="width: 100%;">
                    <option value="cover">Cobrir (Fill)</option>
                    <option value="contain">Conter (Fit)</option>
                </select>
            </div>
            <div style="display: flex; align-items: center; gap: 5px;">
                <input type="checkbox" id="edit-item-rounded" name="roundedcorners">
                <label for="edit-item-rounded">Bordas Curvas</label>
            </div>
            <div>
                <label style="display: block; margin-bottom: 5px;">Z-index (Ordem)</label>
                <div style="display: flex; gap: 5px;">
                    <button type="button" onclick="GaleriaManager.changeModalZ(-1)">-</button>
                    <input type="number" name="positionz" id="edit-item-zindex" value="0" min="0"
                        style="text-align: center; flex: 1;">
                    <button type="button" onclick="GaleriaManager.changeModalZ(1)">+</button>
                </div>
            </div>
            <div>
                <label style="display: block; margin-bottom: 5px;">Capa (Opcional)</label>
                <input type="file" name="cover" accept="image/*,image/gif" style="width: 100%; max-width: 100%; box-sizing: border-box;">
            </div>
            <div id="edit-item-current-cover"
                style="display:none; margin-top: 5px;"></div>
            <hr style="width: 100%; margin: 10px 0; border: none; border-top: 1px solid gray;">
            <div style="display: flex; justify-content: space-between;">
                <button type="button"
                    onclick="event.stopPropagation(); GaleriaManager.deleteItem(document.getElementById('edit-item-id').value)"
                    style="color: red;">Excluir</button>
                <div style="display: flex; gap: 5px;">
                    <button type="button"
                        onclick="document.getElementById('modalEditItem').style.display='none'; document.getElementById('modalBackdrop').style.display='none';">Cancelar</button>
                    <button type="submit" style="font-weight: bold;">Salvar</button>
                </div>
            </div>
        </form>
    </div>
</div>

<!-- Modal Media Fullscreen -->
<div id="modalMedia" class="window"
    style="display: none; position: fixed; top: 50%; left: 50%; transform: translate(-50%, -50%); z-index: 1000; width: fit-content; min-width: 300px; max-width: min(95vw, 1200px); max-height: 90vh; box-sizing: border-box;">
    <div class="window-header">
        <span class="window-title" id="modalMediaTitle">Visualizador</span>
        <button type="button" class="window-btn"
            onclick="document.getElementById('modalMedia').style.display='none'; document.getElementById('modalBackdrop').style.display='none'; document.getElementById('media-container').innerHTML = '';"
            style="float: right;">[Fechar]</button>
    </div>
    <div class="window-content"
        style="text-align: center; overflow: hidden; display: flex; flex-direction: column; align-items: center; justify-content: center;">
        <div id="media-container" style="max-width: 100%; max-height: 75vh;"></div>
        <div id="media-caption" style="margin-top: 10px; color: white; font-weight: bold;"></div>
    </div>
</div>

<div id="modalBackdrop"
    style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.3); z-index: 999;"
    onclick="document.querySelectorAll('.window[id^=\'modal\']').forEach(m => m.style.display='none'); this.style.display='none'; if(document.getElementById('media-container')) document.getElementById('media-container').innerHTML = '';">
</div>
</div>

<script src="/js/features/galeria.js"></script>