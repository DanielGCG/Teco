<style>
    .desktop-hub {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 16px;
        padding: 10px 0;
    }

    .hub-window {
        margin: 0;
        display: flex;
        flex-direction: column;
    }

    .hub-content {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .hub-btn {
        width: 100%;
        padding: 14px;
        font-size: 14px;
        font-weight: bold;
        cursor: pointer;
    }
</style>

<div class="desktop-hub">

    <!-- Janela: Social -->
    <div class="window hub-window">
        <div class="window-header">Social</div>
        <div class="window-content hub-content">
            <button class="hub-btn" onclick="window.location.href='/feed'"><img src="images/inicial/feed.gif"
                    alt="Feed de Posts" style="vertical-align: middle;"></button>
            <button class="hub-btn"
                onclick="window.location.href='/<%= locals.loggedUser ? locals.loggedUser.username : '' %>'"><img
                    src="images/inicial/perfil.gif" alt="Perfil pessoal" style="vertical-align: middle;"></button>
            <button class="hub-btn" onclick="window.location.href='/amigos'"><img src="images/inicial/amigos.gif"
                    alt="Amigos" style="vertical-align: middle;"></button>
        </div>
    </div>

    <!-- Janela: Entretenimento -->
    <div class="window hub-window">
        <div class="window-header">Entretenimento</div>
        <div class="window-content hub-content">
            <button class="hub-btn" onclick="window.location.href='/pet'"><img src="images/inicial/botegotchi.gif"
                    alt="BoteGotchi" style="vertical-align: middle;"></button>
            <button class="hub-btn" onclick="window.location.href='/watchlist'"><img src="images/inicial/watchlist.gif"
                    alt="Watchlist" style="vertical-align: middle;"></button>
            <button class="hub-btn" onclick="window.location.href='/imagemdodia'"><img
                    src="images/inicial/imagemdodia.gif" alt="Imagem do Dia" style="vertical-align: middle;"></button>
            <button class="hub-btn" onclick="window.location.href='/galerias'"><img src="images/inicial/galerias.gif"
                    alt="Galerias" style="vertical-align: middle;"></button>
        </div>
    </div>

    <!-- Janela: Comunicação & Utilidades -->
    <div class="window hub-window">
        <div class="window-header">Comunicação</div>
        <div class="window-content hub-content">
            <button class="hub-btn" onclick="window.location.href='/cartinhas'"><img src="images/inicial/cartinhas.gif"
                    alt="Cartinhas" style="vertical-align: middle;"></button>
            <% if (locals.botecoAnalyticsUrl) { %>
                <button class="hub-btn" onclick="window.open('<%= locals.botecoAnalyticsUrl %>', '_blank')">Boteco
                    Analytics</button>
                <% } %>
                    <% if (locals.loggedUser && locals.loggedUser.roleId <=10) { %>
                        <button class="hub-btn" onclick="window.location.href='/admin'"><img
                                src="images/inicial/admin.gif" alt="Admin" style="vertical-align: middle;"></button>
                        <% } %>
        </div>
    </div>

</div>