<article class="window" style="margin-bottom: 10px;">
    <header class="window-header">Painel Social</header>
    <section class="window-content" style="background: var(--retro-window-bg);">
        <table width="100%" border="1" cellpadding="5" cellspacing="0"
            style="border-collapse: collapse; background: var(--retro-window-bg); text-align: center; border-color: var(--retro-border-dark);">
            <tr>
                <td width="33%">
                    <div style="font-size: 10px; color: var(--retro-border-dark);">Amigos</div>
                    <b id="stat-friends" style="font-size: 14px; color: var(--retro-text);">0</b>
                </td>
                <td width="33%">
                    <div style="font-size: 10px; color: var(--retro-border-dark);">Seguindo</div>
                    <b id="stat-following" style="font-size: 14px; color: var(--retro-text);">0</b>
                </td>
                <td width="34%">
                    <div style="font-size: 10px; color: var(--retro-border-dark);">Seguidores</div>
                    <b id="stat-followers" style="font-size: 14px; color: var(--retro-text);">0</b>
                </td>
            </tr>
        </table>
    </section>
</article>

<article class="window" style="margin-bottom: 10px;">
    <header class="window-header">Buscar Usuários</header>
    <section class="window-content" style="background: var(--retro-bg);">
        <div style="display: flex; gap: 5px;">
            <input type="text" id="user-search-input"
                style="flex-grow: 1; background: var(--retro-window-bg); color: var(--retro-text);"
                placeholder="Digite o nome...">
            <button id="btn-search" class="btn-bold">BUSCAR</button>
            <button id="btn-clear-search" class="btn-micro" style="display: none;">[Fechar]</button>
        </div>
    </section>
</article>

<aside id="search-header" class="window"
    style="display: none; margin-bottom: 10px; background: var(--retro-bg); border: 1px dashed var(--retro-border-dark);">
    <div class="window-content" style="padding: 5px; font-size: 11px; color: var(--retro-text);">
        <b>Resultados da busca:</b>
    </div>
</aside>

<article class="window">
    <nav id="tabs-container" class="window-header"
        style="padding: 0 5px; display: flex; height: 30px; line-height: 30px; background: var(--retro-header-bg); border-bottom: 2px solid var(--retro-border-dark); gap: 2px; align-items: flex-end; justify-content: start;">
        <div class="feed-tab active" data-type="following" onclick="changeSection('following')"
            style="padding: 0 15px; cursor: pointer; height: 24px; line-height: 24px; box-sizing: border-box; font-size: 11px; border: 1px solid var(--retro-border-dark); border-bottom: none; background: var(--retro-sidebar-bg); margin-bottom: -2px;">
            Seguindo</div>
        <div class="feed-tab" data-type="followers" onclick="changeSection('followers')"
            style="padding: 0 15px; cursor: pointer; height: 24px; line-height: 24px; box-sizing: border-box; font-size: 11px; border: 1px solid var(--retro-border-dark); border-bottom: none; background: var(--retro-sidebar-bg); margin-bottom: -2px;">
            Seguidores</div>
    </nav>
    <section class="window-content" style="padding: 0; background: var(--retro-bg);">
        <div id="social-list-container">
            <div style="text-align: center; padding: 20px;">
                <p style="font-size: 11px; color: var(--retro-border-dark);">Carregando dados sociais...</p>
            </div>
        </div>
    </section>
</article>

<style>
    .feed-tab:not(.active) {
        color: var(--retro-text);
        opacity: 0.7;
        filter: grayscale(1);
    }

    .feed-tab.active {
        background: var(--retro-bg) !important;
        font-weight: bold;
        color: var(--retro-text);
        border-top: 1px solid var(--retro-border-light) !important;
        border-left: 1px solid var(--retro-border-light) !important;
        opacity: 1;
        filter: none;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        display: inline-block;
        border: 1px solid var(--retro-text);
    }

    .retro-user-row {
        transition: background 0.1s;
        color: var(--retro-text);
    }

    .retro-user-row:hover {
        background: var(--retro-sidebar-bg);
    }
</style>

<script src="/js/commons/follow-common.js"></script>
<script>
    let currentSection = 'following';
    let isSearching = false;
    let loggedUser = null;
    let dataCache = { following: [], followers: [], friends: new Set(), search: [] };

    document.addEventListener('DOMContentLoaded', async () => {
        try {
            // No layout retro, UserContext ou window.currentUser devem estar disponíveis
            loggedUser = window.currentUser || (typeof UserContext !== 'undefined' ? await UserContext.refresh() : null);

            if (!loggedUser) {
                // Tentar buscar direto da API se falhar
                const res = await fetch('/api/users/me');
                if (res.ok) loggedUser = await res.json();
            }

            await loadAllData();

            const searchInput = document.getElementById('user-search-input');
            const searchBtn = document.getElementById('btn-search');
            const clearBtn = document.getElementById('btn-clear-search');

            const performSearch = async () => {
                const query = searchInput.value.trim();
                if (query.length > 0) {
                    isSearching = true;
                    searchBtn.textContent = '...';
                    await searchUsers(query);
                    searchBtn.textContent = 'BUSCAR';
                    document.getElementById('search-header').style.display = 'block';
                    clearBtn.style.display = 'block';
                    renderList();
                } else {
                    clearSearch();
                }
            };

            searchBtn.onclick = performSearch;
            clearBtn.onclick = clearSearch;
            searchInput.onkeydown = (e) => { if (e.key === 'Enter') performSearch(); };

            changeSection('following');
        } catch (err) {
            console.error('[Social] Erro:', err);
        }
    });

    function updateUserStatusInUI(publicid, status) {
        // Esta função agora é legada, o SocketUI cuida disso globalmente
        if (typeof SocketUI !== 'undefined') {
            SocketUI.updateUserStatus(publicid, status);
        }
    }

    async function loadAllData() {
        if (!loggedUser) return;
        try {
            const [friends, followData, followerData] = await Promise.all([
                FollowAPI.carregarAmigos().catch(() => []),
                fetch(`/api/follows/following/${loggedUser.publicid}`).then(r => r.json()).catch(() => ({ following: [] })),
                fetch(`/api/follows/followers/${loggedUser.publicid}`).then(r => r.json()).catch(() => ({ followers: [] }))
            ]);

            dataCache.friends = new Set((friends || []).map(u => u.publicid));
            dataCache.following = followData.following || [];
            dataCache.followers = followerData.followers || [];

            document.getElementById('stat-friends').textContent = dataCache.friends.size;
            document.getElementById('stat-following').textContent = dataCache.following.length;
            document.getElementById('stat-followers').textContent = dataCache.followers.length;
        } catch (err) { console.error(err); }
    }

    function clearSearch() {
        isSearching = false;
        document.getElementById('user-search-input').value = '';
        document.getElementById('search-header').style.display = 'none';
        document.getElementById('btn-clear-search').style.display = 'none';
        renderList();
    }

    function changeSection(type) {
        if (isSearching) {
            isSearching = false;
            document.getElementById('search-header').style.display = 'none';
            document.getElementById('btn-clear-search').style.display = 'none';
        }
        currentSection = type;
        document.querySelectorAll('.feed-tab').forEach(tab => {
            tab.classList.toggle('active', tab.dataset.type === type);
        });
        renderList();
    }

    function renderList() {
        const container = document.getElementById('social-list-container');
        const list = isSearching ? dataCache.search : dataCache[currentSection];

        if (!list || list.length === 0) {
            container.innerHTML = `<div style="text-align: center; padding: 30px; font-size: 11px; color: var(--retro-border-dark);">Nenhum usuário nesta lista.</div>`;
            return;
        }

        let html = `
            <table width="100%" border="0" cellpadding="8" cellspacing="0" style="background: var(--retro-bg); font-size: 12px;">
                <thead>
                    <tr style="background: var(--retro-sidebar-bg); font-size: 11px; text-transform: uppercase; color: var(--retro-text); border-bottom: 2px solid var(--retro-border-dark);">
                        <th width="50" align="center">ID</th>
                        <th align="left">Usuário</th>
                        <th align="left">Estado & Biografia</th>
                        <th width="160" align="center">Ações</th>
                    </tr>
                </thead>
                <tbody>
        `;

        list.forEach(user => {
            if (loggedUser && user.publicid === loggedUser.publicid) return;

            const isFollowing = dataCache.following.some(f => f.publicid === user.publicid);
            const isFriend = dataCache.friends.has(user.publicid);

            // Note: O SocketUI cuidará de atualizar as cores e textos assim que carregar
            html += `
                <tr class="retro-user-row" data-user-id="${user.publicid}" style="border-bottom: 1px solid var(--retro-border-dark);">
                    <td align="center">
                        <div style="width: 40px; height: 40px; border: 1px solid var(--retro-border-dark); background: var(--retro-window-bg); overflow: hidden;">
                            <img src="${user.profileimage}" width="40" height="40" style="display:block; object-fit: cover;">
                        </div>
                    </td>
                    <td>
                        <div style="margin-bottom: 2px;">
                            <a href="/${user.username}" style="color: black; font-weight: bold; text-decoration: none; font-size: 13px;">${user.username}</a>
                        </div>
                        ${isFriend ? '<span style="background: #e0f0e0; color: #006000; border: 1px solid #006000; font-size: 9px; padding: 0 3px; font-weight: bold; border-radius: 2px;">AMIGO</span>' : ''}
                    </td>
                    <td>
                        <div style="display: flex; align-items: center; gap: 5px; margin-bottom: 4px;">
                            <span class="status-dot" style="background: var(--retro-border-dark);"></span>
                            <span class="status-text" style="font-weight: bold; font-size: 10px; color: var(--retro-text); opacity: 0.8;">Offline</span>
                        </div>
                        <div style="color: var(--retro-text); font-size: 11px; line-height: 1.2; max-width: 250px; overflow: hidden; text-overflow: ellipsis; opacity: 0.9;">
                            ${user.bio || '<i style="color: var(--retro-border-dark);">Sem biografia informada.</i>'}
                        </div>
                    </td>
                    <td align="center">
                        <div style="display: flex; flex-direction: column; gap: 4px; padding: 0 5px;">
                            <button onclick="handleFollow('${user.publicid}', ${isFollowing})" 
                                    style="width: 100%; height: 24px; cursor: pointer; font-size: 11px; font-weight: ${isFollowing ? 'normal' : 'bold'}; ${isFollowing ? 'color: var(--retro-author);' : ''}">
                                ${isFollowing ? 'Deixar Seguir' : 'Seguir'}
                            </button>
                        </div>
                    </td>
                </tr>
            `;
        });

        html += '</tbody></table>';
        container.innerHTML = html;

        // Solicita atualização de status para os elementos recém-renderizados
        if (typeof SocketUI !== 'undefined') {
            SocketUI.requestInitialStatus();
        }
    }

    async function handleFollow(id, isFollowing) {
        const action = isFollowing ? FollowAPI.deixarDeSeguir : FollowAPI.seguir;

        const res = await action(id, {
            showAlert: false,
            confirmMessage: isFollowing ? 'Deseja realmente deixar de seguir este usuário?' : null
        });

        if (res.success) {
            await loadAllData();
            if (isSearching) await searchUsers(document.getElementById('user-search-input').value);
            renderList();
        }
    }

    async function searchUsers(query) {
        if (!query) return;
        try {
            const res = await fetch(`/api/dms/search?q=${encodeURIComponent(query)}`);
            const data = await res.json();
            dataCache.search = data.users || [];
        } catch (err) { console.error('Erro busca:', err); }
    }
</script>