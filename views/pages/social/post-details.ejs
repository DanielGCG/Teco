<div class="window">
    <div class="window-header">
        <span>Visualizar Post</span>
        <div style="float: right;">
            <a href="/" style="color: white; text-decoration: none; font-size: 10px;">[Voltar]</a>
        </div>
    </div>
    <div class="window-content" id="retro-post-details">
        <p style="text-align: center;">Carregando post...</p>
    </div>
</div>

<div class="window" id="retro-comment-box" style="display: none;">
    <div class="window-header">Responder a este post</div>
    <div class="window-content">
        <textarea id="comment-textarea" style="width: 100%; height: 60px; box-sizing: border-box; display: block;" placeholder="Escreva sua resposta..."></textarea>
        <div id="comment-media-preview" style="display: flex; gap: 5px; margin-top: 5px; flex-wrap: wrap;"></div>
        <div style="margin-top: 5px; display: flex; justify-content: space-between; align-items: center; gap: 10px;">
            <div style="flex-grow: 1;">
                <button type="button" onclick="document.getElementById('comment-media-input').click()" style="padding: 2px 15px; font-size: 11px;">ADICIONAR MÍDIA</button>
                <input type="file" id="comment-media-input" multiple accept="image/*,video/*" style="display: none;">
            </div>
            <button onclick="enviarComentario()" style="padding: 2px 20px;">POSTAR</button>
        </div>
    </div>
</div>

<div class="window">
    <div class="window-header">Comentários e Respostas</div>
    <div class="window-content" id="retro-comments-list">
        <!-- Comentários aqui -->
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const postId = "<%= locals.postId %>";
        let selectedCommentFiles = [];

        // Inicializar Handlers Globais do Posts Retrô
        RetroPosts.initHandlers(() => carregarPost());

        async function carregarPost() {
            try {
                const res = await fetch(`/api/posts/${postId}`);
                if (!res.ok) throw new Error('Falha ao carregar');
                const post = await res.json();
                
                document.getElementById('retro-comment-box').style.display = 'block';

                renderPostDetails(post);
                carregarComentarios();
            } catch (e) {
                document.getElementById('retro-post-details').innerHTML = '<p style="color:red;">Erro ao localizar post.</p>';
            }
        }

        function renderPostDetails(post) {  
            const currentUsername = "<%= locals.loggedUser ? locals.loggedUser.username : '' %>";
            const currentUserRole = parseInt("<%= locals.loggedUser ? locals.loggedUser.roleId : 20 %>");
            document.getElementById('retro-post-details').innerHTML = RetroPosts.renderPost(post, currentUsername, currentUserRole);
        }

        async function carregarComentarios() {
            try {
                const res = await fetch(`/api/posts/${postId}/replies`);
                const replies = await res.json();
                const container = document.getElementById('retro-comments-list');
                container.innerHTML = '';

                if (replies.length === 0) {
                    container.innerHTML = '<p style="text-align: center; color: #808080;">Ninguém comentou ainda. Seja o primeiro!</p>';
                    return;
                }

                const currentUsername = "<%= locals.loggedUser ? locals.loggedUser.username : '' %>";
                const currentUserRole = parseInt("<%= locals.loggedUser ? locals.loggedUser.roleId : 20 %>");
                replies.forEach(r => {
                    container.insertAdjacentHTML('beforeend', RetroPosts.renderPost(r, currentUsername, currentUserRole));
                });
            } catch (e) { console.error(e); }
        }

        window.handleRetroDelete = async (targetId) => {
            const confirmed = await window.confirmRetro('Tem certeza que deseja apagar esta mensagem?', 'Confirmar Exclusão');
            if (!confirmed) return;

            try {
                const res = await fetch(`/api/posts/${targetId}`, { method: 'DELETE' });
                if (res.ok) {
                    if (targetId === postId) {
                        alert('Post principal deletado. Voltando...');
                        window.history.back();
                    } else {
                        const el = document.getElementById(`post-${targetId}`);
                        if (el) el.style.display = 'none';
                    }
                }
            } catch (e) { console.error(e); }
        };

        window.enviarComentario = async function() {
            const textarea = document.getElementById('comment-textarea');
            const content = textarea.value.trim();
            if (!content && selectedCommentFiles.length === 0) return;

            const formData = new FormData();
            formData.append('content', content);
            formData.append('type', 'comment');
            formData.append('attachedPostPublicId', postId);
            selectedCommentFiles.forEach(file => formData.append('media', file));

            try {
                const res = await fetch('/api/posts', { method: 'POST', body: formData });
                if (res.ok) {
                    textarea.value = '';
                    document.getElementById('comment-media-input').value = '';
                    document.getElementById('comment-media-preview').innerHTML = '';
                    selectedCommentFiles = [];
                    carregarPost(); 
                }
            } catch (e) { alert('Erro ao comentar!'); }
        }

        document.getElementById('comment-media-input').addEventListener('change', (e) => {
            const preview = document.getElementById('comment-media-preview');
            preview.innerHTML = '';
            selectedCommentFiles = Array.from(e.target.files);
            selectedCommentFiles.forEach(file => {
                const reader = new FileReader();
                reader.onload = (ev) => {
                    const img = document.createElement('img');
                    img.src = ev.target.result;
                    img.style = "width: 40px; height: 40px; border: 1px solid var(--retro-border-dark); object-fit: cover;";
                    preview.appendChild(img);
                };
                reader.readAsDataURL(file);
            });
        });

        carregarPost();
    });
</script>
