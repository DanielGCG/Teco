<style>
  .edit-container {
    display: flex; 
    flex-direction: column;
    gap: 15px; 
    align-items: center;
  }
  .preview-col {
    width: 100%;
    max-width: 400px;
  }
  .form-col {
    width: 100%;
    max-width: 600px;
  }
</style>

<div class="window" style="max-width: 800px; margin: 10px auto;">
  <div class="window-header">
    <span>Editar Perfil</span>
  </div>
  <div class="window-content" style="padding: 10px;">
    <div class="edit-container" style="gap: 10px;">
      <!-- Preview em Cima (Cópia fiel do retro-profile) -->
      <div class="preview-col" style="width: 100%; max-width: 100%;">
        <div class="window" style="margin-bottom: 10px;">
          <div class="window-header" style="font-size: 10px;">Preview do Perfil</div>
          <div class="window-content" style="padding: 10px;">
            <div style="display: flex; gap: 15px; align-items: flex-start;">
              <div style="text-align: center; width: 130px; flex-shrink: 0;">
                <div style="position: relative; display: inline-block;">
                  <img id="preview-pf" src="" border="1" style="width: 100px; height: 100px; object-fit: cover; background: var(--retro-window-bg); border: 1px solid var(--retro-border-dark);">
                  <span class="status-dot" style="position: absolute; bottom: 5px; right: 5px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid white; background: #4caf50;"></span>
                </div>
                <div id="preview-username-text" style="display: block; margin-top: 3px;">...</div>
                <div id="preview-pronouns-text" style="font-size: 11px; margin-top: 3px; color: var(--retro-border-dark);"></div>
                <div style="margin-top: 8px;">
                  <button style="width: 100%; font-size: 11px; cursor: default;">EDITAR</button>
                </div>
              </div>
              <div style="flex-grow: 1; display: flex; flex-direction: row; gap: 15px; align-items: stretch;">
                <div style="display: flex; flex-direction: column; gap: 10px; width: 180px; flex-shrink: 0;">
                  <div class="window" style="flex: 1; margin-bottom: 0; display: flex; flex-direction: column;">
                    <div id="preview-bio-text" class="window-content" style="flex-grow: 1; min-height: 40px; max-height: 85px; overflow-y: auto; font-size: 12px; padding: 5px; word-wrap: break-word; overflow-wrap: break-word;"></div>
                  </div>
                  <div class="window" style="margin-bottom: 0;">
                    <div class="window-content" style="padding: 5px; font-size: 11px; display: flex; gap: 10px; flex-wrap: wrap;">
                      <span>Posts: <b id="preview-post-count">0</b></span>
                      <span id="preview-joined-date" style="color: var(--retro-border-dark);">...</span>
                    </div>
                  </div>
                </div>
                <div id="preview-banner-container" class="window" style="display: none; margin-bottom: 0; flex-grow: 1; position: relative; overflow: hidden; display: flex; flex-direction: column; min-width: 250px;">
                  <div class="window-content" style="padding: 0; flex-grow: 1; height: 100%; min-height: 125px; background: #000; display: flex; align-items: stretch; justify-content: center; overflow: hidden;">
                    <img id="preview-banner-img" src="" style="width: 100%; height: 100%; height: 160px; object-fit: cover; display: block; image-rendering: pixelated;">
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Campos em Baixo -->
      <div class="form-col" style="overflow: hidden;">
        <form id="edit-profile-form">
          <table border="0" cellpadding="2" cellspacing="0" width="100%" style="font-size: 11px; table-layout: fixed;">
            <tr>
              <td width="60"><b>Usuário:</b></td>
              <td>
                <input type="text" id="username" name="username" maxlength="12" style="width: 100%; box-sizing: border-box; height: 18px;" required>
              </td>
            </tr>
            <tr>
              <td><b>Pronomes:</b></td>
              <td>
                <input type="text" id="pronouns" name="pronouns" maxlength="12" style="width: 100%; box-sizing: border-box; height: 18px;" placeholder="ele/ela/elu">
              </td>
            </tr>
            <tr>
              <td><b>Last.fm:</b></td>
              <td>
                <input type="text" id="lastfmusername" name="lastfmusername" maxlength="64" style="width: 100%; box-sizing: border-box; height: 18px;">
              </td>
            </tr>
            <tr>
              <td valign="top"><b>Bio:</b></td>
              <td>
                <textarea id="bio" name="bio" rows="2" maxlength="80" style="width: 100%; resize: none; box-sizing: border-box; display: block; height: 35px; font-family: sans-serif; font-size: 11px;" oninput="atualizarContadorBio()"></textarea>
                <div align="right"><small id="bio-contador" style="font-size: 9px;">0 / 80</small></div>
              </td>
            </tr>
            <tr>
              <td><b>Avatar:</b></td>
              <td>
                <input type="url" id="profileimage" name="profileimage" style="width: 100%; box-sizing: border-box; height: 18px; font-size: 10px;">
                <input type="file" id="profile_file" name="profile_file" accept="image/*" style="font-size: 9px; margin-top: 2px; width: 100%;">
              </td>
            </tr>
            <tr>
              <td><b>Fundo:</b></td>
              <td>
                <input type="url" id="backgroundimage" name="backgroundimage" style="width: 100%; box-sizing: border-box; height: 18px; font-size: 10px;">
                <input type="file" id="background_file" name="background_file" accept="image/*" style="font-size: 9px; margin-top: 2px; width: 100%;">
              </td>
            </tr>
            <tr>
              <td colspan="2" align="center" style="padding-top: 10px;">
                <button type="submit" style="padding: 2px 15px; cursor: pointer; font-weight: bold; font-size: 11px;">GRAVAR ALTERAÇÕES</button>
              </td>
            </tr>
          </table>
        </form>

        <div class="window" style="margin-top: 10px;">
          <div class="window-header">Segurança</div>
          <div class="window-content" style="padding: 5px;">
            <form id="change-password-form">
              <table border="0" cellpadding="2" cellspacing="0" width="100%" style="font-size: 11px; table-layout: fixed;">
                <tr>
                  <td width="60"><b>Senha:</b></td>
                  <td><input type="password" id="current_password" required style="width: 100%; box-sizing: border-box; height: 18px;"></td>
                </tr>
                <tr>
                  <td><b>Nova:</b></td>
                  <td><input type="password" id="new_password" required style="width: 100%; box-sizing: border-box; height: 18px;"></td>
                </tr>
                <tr>
                  <td><b>Repetir:</b></td>
                  <td><input type="password" id="confirm_password" required style="width: 100%; box-sizing: border-box; height: 18px;"></td>
                </tr>
                <tr>
                  <td colspan="2" align="center" style="padding-top: 5px;">
                    <button type="submit" style="cursor: pointer; font-size: 11px;">ALTERAR SENHA</button>
                  </td>
                </tr>
              </table>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
function atualizarContadorBio() {
  const bio = document.getElementById('bio');
  const contador = document.getElementById('bio-contador');
  const previewBio = document.getElementById('preview-bio-text');
  contador.textContent = `${bio.value.length} / 80`;
  previewBio.innerHTML = bio.value ? bio.value.replace(/\n/g, '<br>') : '...';
}

function normalizarUsername(username) {
  username = username.trim();
  if (username.startsWith('@')) username = username.substring(1);
  return username.toLowerCase();
}

function atualizarPreviews(user) {
  const previewBannerImg = document.getElementById('preview-banner-img');
  const previewBannerContainer = document.getElementById('preview-banner-container');
  const previewPf = document.getElementById('preview-pf');
  const previewUser = document.getElementById('preview-username-text');
  const previewPronouns = document.getElementById('preview-pronouns-text');
  const previewPostCount = document.getElementById('preview-post-count');
  const previewJoinedDate = document.getElementById('preview-joined-date');

  if(user.backgroundimage){
    previewBannerImg.src = user.backgroundimage;
    previewBannerContainer.style.display = 'flex';
    document.getElementById('backgroundimage').value = user.backgroundimage;
  } else {
    previewBannerContainer.style.display = 'none';
  }

  if(user.profileimage){
    previewPf.src = user.profileimage;
    document.getElementById('profileimage').value = user.profileimage;
  }
  
  const cleanUsername = user.username.startsWith('@') ? user.username.substring(1) : user.username;
  document.getElementById('username').value = cleanUsername;
  previewUser.textContent = cleanUsername;
  document.getElementById('bio').value = user.bio || '';
  document.getElementById('pronouns').value = user.pronouns || '';
  previewPronouns.textContent = user.pronouns || '';
  document.getElementById('lastfmusername').value = user.lastfmusername || '';
  
  if (previewPostCount) previewPostCount.textContent = user.postcount || 0;
  if (previewJoinedDate && user.createdat) {
    const date = new Date(user.createdat).toLocaleDateString();
    previewJoinedDate.textContent = `Membro desde: ${date}`;
  }

  atualizarContadorBio();
}

async function carregarPerfil() {
  try {
    const res = await fetch('/api/users/me', { credentials: 'include' });
    if(res.ok){
      const user = await res.json();
      atualizarPreviews(user);
    }
  } catch(err){ console.error(err); }
}

document.getElementById('username').addEventListener('input', function() {
  const val = normalizarUsername(this.value);
  document.getElementById('preview-username-text').textContent = val || '...';
});

document.getElementById('pronouns').addEventListener('input', function() {
  document.getElementById('preview-pronouns-text').textContent = this.value;
});

document.getElementById('backgroundimage').addEventListener('input', function() {
  const img = document.getElementById('preview-banner-img');
  const container = document.getElementById('preview-banner-container');
  if (this.value) {
    img.src = this.value;
    container.style.display = 'flex';
  } else {
    container.style.display = 'none';
  }
});

document.getElementById('profileimage').addEventListener('input', function() {
  document.getElementById('preview-pf').src = this.value;
});

// Preview em tempo real para arquivos
document.getElementById('profile_file').addEventListener('change', function() {
  const file = this.files[0];
  if (file) {
    const reader = new FileReader();
    reader.onload = function(e) {
      document.getElementById('preview-pf').src = e.target.result;
    }
    reader.readAsDataURL(file);
  }
});

document.getElementById('background_file').addEventListener('change', function() {
  const file = this.files[0];
  if (file) {
    const reader = new FileReader();
    reader.onload = function(e) {
      const img = document.getElementById('preview-banner-img');
      const container = document.getElementById('preview-banner-container');
      img.src = e.target.result;
      container.style.display = 'flex';
    }
    reader.readAsDataURL(file);
  }
});

document.getElementById('edit-profile-form').addEventListener('submit', async function(e){
  e.preventDefault();
  const formData = new FormData();
  formData.append('username', '@' + normalizarUsername(document.getElementById('username').value));
  formData.append('backgroundimage', document.getElementById('backgroundimage').value);
  formData.append('profileimage', document.getElementById('profileimage').value);
  formData.append('bio', document.getElementById('bio').value);
  formData.append('pronouns', document.getElementById('pronouns').value);
  formData.append('lastfmusername', document.getElementById('lastfmusername').value);

  const bgFile = document.getElementById('background_file').files[0];
  const pfFile = document.getElementById('profile_file').files[0];
  if(bgFile) formData.append('background_file', bgFile);
  if(pfFile) formData.append('profile_file', pfFile);

  try {
    const res = await fetch('/api/users/me', { method: 'PUT', body: formData });
    const data = await res.json();
    if(res.ok) {
        await alert("Perfil atualizado com sucesso!");
        location.reload();
    } else { 
        let msg = data.message;
        if (data.errors && Array.isArray(data.errors)) {
            msg = data.errors.map(err => err.message || err.msg).join('\n');
        }
        await alert(new Error(msg || "Erro ao atualizar perfil.")); 
    }
  } catch(err){ 
      await alert(new Error("Erro de conexão ao salvar perfil.")); 
  }
});

document.getElementById('change-password-form').addEventListener('submit', async function(e){
  e.preventDefault();
  const currentPassword = document.getElementById('current_password').value;
  const newPassword = document.getElementById('new_password').value;
  const confirmPassword = document.getElementById('confirm_password').value;
  if(newPassword !== confirmPassword) return await alert(new Error("A nova senha e a confirmação não coincidem."));

  try {
    const res = await fetch('/api/users/me/password', {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ currentPassword, newPassword })
    });
    
    const data = await res.json();
    if(res.ok) {
        await alert("Senha alterada com sucesso!");
        this.reset();
    } else { 
        // Formatar o aviso para evitar vazamento do banco
        let msg = data.message;
        if (data.errors && Array.isArray(data.errors)) {
            msg = data.errors.map(err => err.msg || err.message).join('\n');
        }
        await alert(new Error(msg || "Ocorreu um problema ao mudar a senha.")); 
    }
  } catch(err){ 
      await alert(new Error("Erro de conexão ao mudar a senha. Verifique sua internet.")); 
  }
});

carregarPerfil();
</script>
