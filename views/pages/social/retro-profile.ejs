<div class="window profile-window">
    <div class="window-content">
        <div class="profile-container">
            <div class="profile-avatar-col">
                <div id="profile-avatar-container" style="position: relative; display: inline-block;">
                    <img id="retro-avatar" src="" border="1" style="width: 100px; height: 100px; object-fit: cover; background: var(--retro-window-bg);  border: 1px solid var(--retro-border-dark);">
                    <span id="user-status-dot" class="status-dot" style="position: absolute; bottom: 5px; right: 5px; width: 15px; height: 15px; border-radius: 50%; border: 2px solid white; background: gray;"></span>
                </div>
                <span id="retro-username">...</span>
                <div class="roles-pronouns-container" style="display: flex; justify-content: space-evenly; align-items: center; margin-top: 3px; font-weight: bold;">
                    <div id="retro-role" style="font-size: 10px; text-transform: uppercase; color: #555;"></div>
                    <div id="retro-pronouns" style="font-size: 11px; color: var(--retro-border-dark);"></div>
                </div>
                <div class="buttons-container" style="margin-top: 8px; text-align: center;">
                    <button id="btn-edit" class="btn-block btn-sm" style="display: none; margin: 0 auto;" onclick="window.location.href='/editar'">EDITAR</button>
                    <button id="btn-follow" class="btn-block btn-sm" style="display: none; margin: 0 auto;">SEGUIR</button>
                </div>
            </div>
            <div class="profile-info-col">
                <div class="profile-stats-col">
                    <div class="window bio-window" style="flex: 1; margin-bottom: 0; display: flex; flex-direction: column;">
                        <div id="retro-bio" class="window-content" style="flex-grow: 1; min-height: 40px; max-height: 85px; overflow-y: auto; font-size: 12px; padding: 5px; word-wrap: break-word; overflow-wrap: break-word;"></div>
                    </div>
                    <div class="window stats-window" style="margin-bottom: 0;">
                        <div class="window-content" style="padding: 5px; font-size: 11px; display: flex; gap: 10px; flex-wrap: wrap;">
                            <span>Posts: <b id="retro-post-count">0</b></span>
                            <span id="retro-joined-date" style="color: var(--retro-border-dark);"></span>
                        </div>
                    </div>
                </div>
                <div id="retro-banner-container" class="window" style="display: none; margin-bottom: 0; flex-grow: 1; position: relative; overflow: hidden; display: flex; flex-direction: column;">
                    <div class="window-content" style="padding: 0; flex-grow: 1; height: 100%; min-height: 125px; background: #000; display: flex; align-items: stretch; justify-content: center; overflow: hidden;">
                        <img id="retro-banner-img" src="" style="width: 100%; height: 100%; height: 160px; object-fit: cover; display: block; image-rendering: pixelated; cursor: pointer;" onclick="window.open(this.src)">
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="profile-bottom-layout">
    <div class="profile-bottom-sidebar">
        <div class="window">
            <div class="window-header">Badges</div>
            <div id="retro-badges" class="window-content">
                <span style="font-size: 11px; color: gray;">Carregando...</span>
            </div>
        </div>

        <!-- BotecoAnalytics Widget -->
        <div id="music-widget" class="window" style="display: none;">
            <div class="window-header">Música</div>
            <div class="window-content" style="padding: 5px; background: #fff; border: 1px inset #808080;">
                <div id="now-playing" style="display: flex; gap: 8px; align-items: center; padding-bottom: 5px; border-bottom: 1px dashed #ccc;">
                    <div style="width: 40px; height: 40px; flex-shrink: 0; background: #eee; border: 1px solid #808080; position: relative; overflow: hidden;">
                        <img id="music-now-image" src="/images/default-music.png" style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                    <div style="line-height: 1.1; overflow: hidden;">
                        <div id="music-now-status-text" style="font-size: 9px; text-transform: uppercase; color: #666; font-weight: bold;">Ouvindo agora</div>
                        <div id="music-now-name" style="font-size: 12px; font-weight: bold; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">-</div>
                        <div id="music-now-artist" style="font-size: 11px; color: #444;">-</div>
                    </div>
                </div>
                <div id="top-weekly" style="display: flex; gap: 8px; align-items: center; margin-top: 5px;">
                    <div style="width: 32px; height: 32px; flex-shrink: 0; background: #eee; border: 1px solid #808080;">
                        <img id="music-top-image" src="/images/default-music.png" style="width: 100%; height: 100%; object-fit: cover;">
                    </div>
                    <div style="line-height: 1.1; overflow: hidden;">
                        <div style="font-size: 9px; text-transform: uppercase; color: #666; font-weight: bold;">Top da Semana</div>
                        <div id="music-top-name" style="font-size: 11px; font-weight: bold; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">-</div>
                        <div id="music-top-artist" style="font-size: 10px; color: #444;">-</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="window">
            <div class="window-header">Galerias</div>
            <div id="retro-galerias" class="window-content">
                <span style="font-size: 11px; color: gray;">Carregando...</span>
            </div>
        </div>
        <div class="window">
            <div class="window-header">Amigos</div>
            <div id="retro-amigos" class="window-content">
                <span style="font-size: 11px; color: gray;">Carregando...</span>
            </div>
        </div>
    </div>

    <div class="profile-bottom-main">
        <div class="window" id="retro-new-post-area" style="display: none; margin-bottom: 15px;">
            <div class="window-content">
                <textarea id="retro-post-textarea" style="width: 100%; height: 60px; box-sizing: border-box; display: block;" placeholder="No que você está pensando agora?"></textarea>
                <div id="retro-media-preview" style="display: flex; gap: 5px; margin-top: 5px; flex-wrap: wrap;"></div>
                <div style="margin-top: 5px; display: flex; justify-content: space-between; align-items: center; gap: 10px;">
                    <div style="flex-grow: 1;">
                        <button type="button" onclick="document.getElementById('retro-post-media').click()" class="btn-sm">ADICIONAR MÍDIA</button>
                        <input type="file" id="retro-post-media" multiple accept="image/*,video/*" style="display: none;">
                    </div>
                    <button id="btn-retro-postar" class="btn-bold" style="padding: 2px 20px;">POSTAR</button>
                </div>
            </div>
        </div>

        <div class="window">
            <div class="window-content" id="feed-container">
                <p style="text-align: center; color: #808080;">Aguardando posts do servidor...</p>
            </div>
        </div>
    </div>
</div>

<link rel="stylesheet" href="/styles/profile.css">

<script src="/js/commons/follow-common.js"></script>
<script src="/js/features/post.js"></script>
<script>
    const pathParts = window.location.pathname.split('/');
    const username = pathParts[1];
    window.username = username;
    window.profileUserId = null;

    async function carregarPerfil() {
        try {
            const response = await fetch(`/api/users/${username}`, { credentials: "include" });
            if (!response.ok) return;

            const user = await response.json();
            window.profileUserId = user.publicid;

            // Identificador para o SocketUI atualizar o status em tempo real
            const avatarContainer = document.getElementById('profile-avatar-container');
            if (avatarContainer) {
                avatarContainer.setAttribute('data-user-id', user.publicid);
                const statusDot = document.getElementById('user-status-dot');
                if (statusDot) statusDot.classList.add('status-dot');
            }

            document.getElementById("retro-username").textContent = user.username;
            document.getElementById("retro-avatar").src = user.profileimage;
            
            // Exibir o cargo (role)
            const roleEl = document.getElementById("retro-role");
            if (user.role) {
                roleEl.textContent = user.role.name;
                // Cores baseadas no cargo
                if (user.roleId === 1) roleEl.style.color = "#d32f2f"; // Dono
                else if (user.roleId <= 5) roleEl.style.color = "#1976d2"; // Admin
                else if (user.roleId <= 10) roleEl.style.color = "#388e3c"; // Mod
            }
            
            if (user.bannerimage) {
                const bannerContainer = document.getElementById("retro-banner-container");
                const bannerImg = document.getElementById("retro-banner-img");
                bannerContainer.style.display = "block";
                bannerImg.src = user.bannerimage;
                const profileContainer = document.querySelector('.profile-container');
                if (profileContainer) profileContainer.classList.add('has-banner');
            }
            if (user.backgroundcolor) {
                document.body.style.backgroundColor = user.backgroundcolor;
            }
            if (user.backgroundimage) {
                document.body.style.backgroundImage = `url(${user.backgroundimage})`;
                if (user.backgroundfill === 'repeat') {
                    document.body.style.backgroundSize = 'auto';
                    document.body.style.backgroundRepeat = 'repeat';
                } else {
                    document.body.style.backgroundSize = 'cover';
                    document.body.style.backgroundRepeat = 'no-repeat';
                    document.body.style.backgroundAttachment = 'fixed';
                }
            }

            if (user.createdat) {
                const date = new Date(user.createdat).toLocaleDateString();
                document.getElementById("retro-joined-date").textContent = `Desde: ${date}`;
            }

            const pronounsEl = document.getElementById("retro-pronouns");
            if (user.pronouns) {
                pronounsEl.textContent = user.pronouns;
                pronounsEl.style.display = "block";
            } else {
                pronounsEl.textContent = "";
                pronounsEl.style.display = "none";
            }

            document.getElementById("retro-post-count").textContent = user.postcount || 0;
            document.getElementById("retro-bio").innerHTML = user.bio ? user.bio.replace(/\n/g, '<br>') : 'Nenhuma biografia disponível.';

            if (window.currentUser) {
                if (window.currentUser.publicid === user.publicid) {
                    document.getElementById("btn-edit").style.display = "block";
                    document.getElementById("retro-new-post-area").style.display = "block";
                } else {
                    document.getElementById("btn-follow").style.display = "block";
                    verificarSeguimento(user.publicid);
                }
            }

            carregarBadges(user.publicid);
            carregarGalerias(user.publicid);
            carregarAmigos(user.publicid);
            
            // Usa o lastfmusername se existir, senão não tenta carregar
            if (user.lastfmusername) {
                carregarMusicasWidget(user.lastfmusername);
            } else {
                console.log("Usuário não possui Last.fm configurado.");
                document.getElementById('music-widget').style.display = 'none';
            }

            // Carregar Feed usando a mesma lógica da home
            loadUserPosts();
            
        } catch (error) {
            console.error("Erro ao carregar perfil:", error);
        }
    }

    async function carregarMusicasWidget(lastfmUsername) {
        if (!lastfmUsername) return;
        const widgetArea = document.getElementById('music-widget');
        try {
            const res = await fetch(`/api/users/music-widget/${encodeURIComponent(lastfmUsername)}`, { 
                credentials: "include" 
            });
            if (!res.ok) {
                console.error(`Erro na API de Música (${res.status}): ${res.url}`);
                return;
            }

            const data = await res.json();
            if (!data.lastTrack && !data.weeklyTopTrack) return;

            widgetArea.style.display = 'block';

            if (data.lastTrack) {
                document.getElementById('music-now-name').textContent = data.lastTrack.name;
                document.getElementById('music-now-artist').textContent = data.lastTrack.artist;
                if (data.lastTrack.image) document.getElementById('music-now-image').src = data.lastTrack.image;
                
                const statusText = document.getElementById('music-now-status-text');
                
                if (data.lastTrack.isNowPlaying) {
                    statusText.textContent = 'Ouvindo agora';
                    statusText.style.color = '#4caf50';
                } else {
                    statusText.textContent = 'Última ouvida';
                    statusText.style.color = '#666';
                }
            } else {
                document.getElementById('now-playing').style.display = 'none';
            }

            if (data.weeklyTopTrack) {
                document.getElementById('music-top-name').textContent = data.weeklyTopTrack.name;
                document.getElementById('music-top-artist').textContent = data.weeklyTopTrack.artist;
                if (data.weeklyTopTrack.image) document.getElementById('music-top-image').src = data.weeklyTopTrack.image;
            } else {
                document.getElementById('top-weekly').style.display = 'none';
            }
        } catch (e) {
            console.error('Erro ao carregar widget de música:', e);
        }
    }

    async function verificarSeguimento(targetId) {
        const btn = document.getElementById("btn-follow");
        try {
            const status = await FollowAPI.verificarStatus(targetId);
            const config = status.isMutual 
                ? { text: 'Amigos', action: FollowAPI.deixarDeSeguir }
                : status.following 
                    ? { text: 'Seguindo', action: FollowAPI.deixarDeSeguir }
                    : status.followedBy 
                        ? { text: 'Seguir de volta', action: FollowAPI.seguir }
                        : { text: 'Seguir', action: FollowAPI.seguir };

            btn.textContent = config.text;
            btn.onclick = async () => {
                await config.action(targetId, { showAlert: false });
                verificarSeguimento(targetId);
                carregarAmigos(profileUserId);
            };
        } catch (e) {}
    }

    let profileLazyReset = null;

    async function loadUserPosts() {
        try {
            const res = await fetch(`/api/posts/feed?type=user&username=${username}&limit=20&offset=0`, { credentials: 'include' });
            if (res.ok) {
                let posts = await res.json();
                const container = document.getElementById('feed-container');
                container.innerHTML = '';
                
                // O servidor pode retornar posts de terceiros se o type for diferente, mas no user feed geralmente já vem filtrado.
                // Filtramos por segurança para garantir que apenas o dono do perfil apareça.
                const userPosts = posts.filter(post => post.author.username === username);

                if (!userPosts || userPosts.length === 0) {
                    container.innerHTML = '<p style="text-align: center; color: #808080; padding: 20px;">Este usuário ainda não postou nada.</p>';
                    return;
                }

                const currentUsername = "<%= locals.loggedUser ? locals.loggedUser.username : '' %>";
                const currentUserRole = parseInt("<%= locals.loggedUser ? locals.loggedUser.roleId : 20 %>");
                userPosts.forEach(post => {
                    container.insertAdjacentHTML('beforeend', RetroPosts.renderPost(post, currentUsername, currentUserRole));
                });

                // Inicializar ou re-inicializar o Lazy Loading após o carregamento inicial bem sucedido
                if (!profileLazyReset) {
                    profileLazyReset = RetroPosts.setupInfiniteScroll(
                        'feed-container', 
                        `/api/posts/feed?type=user&username=${username}`, 
                        currentUsername
                    );
                } else {
                    profileLazyReset();
                }
            }
        } catch (e) {
            console.error('Erro ao carregar posts:', e);
            document.getElementById('feed-container').innerHTML = '<p style="text-align: center; color: red;">Erro ao carregar posts.</p>';
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        // Inicializar Handlers Globais do Posts Retrô
        RetroPosts.initHandlers(() => loadUserPosts());
        
        carregarPerfil();
    });

    async function carregarBadges(userId) {
        const res = await fetch(`/api/badges/user/${userId}`);
        const data = await res.json();
        const list = document.getElementById("retro-badges");
        if (data.length) {
            list.innerHTML = data.map(b => `<div class="retro-badge-item" title="${b.name}"><img src="${b.url}"></div>`).join('');
        } else {
            list.innerHTML = '<span style="font-size: 11px;">Nenhum badge</span>';
        }
    }

    async function carregarGalerias(userId) {
        const res = await fetch(`/api/galeria/user/${userId}`);
        const data = await res.json();
        const list = document.getElementById("retro-galerias");
        if (data.success && data.galleries.length) {
            list.innerHTML = data.galleries.map(g => `
                <a href="/galeria/${g.publicid}" class="retro-gallery-item">
                    <img src="${g.coverurl}">
                    <div>${g.name}</div>
                </a>
            `).join('');
        } else {
            list.innerHTML = '<span style="font-size: 11px;">Nenhuma galeria</span>';
        }
    }

    async function carregarAmigos(userId) {
        const friends = await FollowAPI.carregarAmigos(userId);
        const list = document.getElementById("retro-amigos");
        if (friends && friends.length) {
            list.innerHTML = friends.map(f => `
                <a href="/${f.username}" class="retro-friend-item" data-user-id="${f.publicid}">
                    <img src="${f.profileimage}" border="1">
                    <span>${f.username}</span>
                    <span class="status-dot" style="width: 8px; height: 8px; border-radius: 50%; display: inline-block; margin-left: auto;"></span>
                </a>
            `).join('');
            
            // Solicita os status iniciais dos amigos carregados
            if (typeof SocketUI !== 'undefined') SocketUI.requestInitialStatus();
        } else {
            list.innerHTML = '<span style="font-size: 11px;">Nenhum amigo</span>';
        }
    }

    document.addEventListener('DOMContentLoaded', () => {
        carregarPerfil();

        // Lógica de Postar Retrô Sincronizada
        const textarea = document.getElementById('retro-post-textarea');
        const mediaInput = document.getElementById('retro-post-media');
        const btnPostar = document.getElementById('btn-retro-postar');
        const preview = document.getElementById('retro-media-preview');
        let selectedFiles = [];

        mediaInput.addEventListener('change', (e) => {
            preview.innerHTML = '';
            selectedFiles = Array.from(e.target.files);
            selectedFiles.forEach(file => {
                const reader = new FileReader();
                reader.onload = (ev) => {
                    const img = document.createElement('img');
                    img.src = ev.target.result;
                    img.style = "width: 50px; height: 50px; border: 1px solid var(--retro-border-dark); object-fit: cover;";
                    preview.appendChild(img);
                };
                reader.readAsDataURL(file);
            });
        });

        btnPostar.addEventListener('click', async () => {
            const content = textarea.value.trim();
            if (!content && selectedFiles.length === 0) return;

            btnPostar.disabled = true;
            btnPostar.textContent = '...';

            const formData = new FormData();
            formData.append('content', content);
            formData.append('type', 'post');
            selectedFiles.forEach(file => formData.append('media', file));

            try {
                const res = await fetch('/api/posts', { method: 'POST', body: formData });
                if (res.ok) {
                    textarea.value = '';
                    mediaInput.value = '';
                    preview.innerHTML = '';
                    selectedFiles = [];
                    loadUserPosts();
                }
            } catch (e) {
                alert('Erro ao postar');
            } finally {
                btnPostar.disabled = false;
                btnPostar.textContent = 'POSTAR';
            }
        });
    });
</script>
